@prefix sc: <https://spectacular-voyage.github.io/stagecraft/ontology/> .
@prefix sc-sh: <https://spectacular-voyage.github.io/stagecraft/shacl/> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

sc-sh:ProjectionNotificationShape
  a sh:NodeShape ;
  sh:targetClass sc:ProjectionNotification ;
  sh:property [
    sh:path sc:signal ;
    sh:hasValue "projection-ready" ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [
    sh:path sc:authorityRecord ;
    sh:nodeKind sh:IRI ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [
    sh:path sc:committedEvent ;
    sh:nodeKind sh:IRI ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [
    sh:path sc:commitCertificate ;
    sh:nodeKind sh:IRI ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [
    sh:path sc:projectionState ;
    sh:nodeKind sh:IRI ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [
    sh:path sc:stateMutation ;
    sh:nodeKind sh:IRI ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [
    sh:path sc:projectionPath ;
    sh:datatype xsd:string ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [
    sh:path sc:resync ;
    sh:node sc-sh:ResyncShape ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [
    sh:path sc:barred ;
    sh:maxCount 0 ;
    sh:message "ProjectionNotification must remain pointer-only and not carry accepted state facts." ;
  ] ;
  sh:property [
    sh:path sc:lastAuthorityRecord ;
    sh:maxCount 0 ;
    sh:message "ProjectionNotification must point to authority records without embedding accepted state provenance fields." ;
  ] .

sc-sh:ProjectionRequestShape
  a sh:NodeShape ;
  sh:targetClass sc:ProjectionRequest ;
  sh:property [
    sh:path sc:envelopeType ;
    sh:hasValue "stagecraft.projection.request.v1" ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [
    sh:path sc:requestedByParticipant ;
    sh:nodeKind sh:IRI ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [
    sh:path sc:projectionId ;
    sh:nodeKind sh:IRI ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [
    sh:path sc:historyScope ;
    sh:nodeKind sh:IRI ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [
    sh:path sc:branchScope ;
    sh:nodeKind sh:IRI ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [
    sh:path sc:temporalScope ;
    sh:nodeKind sh:IRI ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [
    sh:path sc:resourcePointers ;
    sh:node sc-sh:ResourcePointersShape ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [
    sh:path sc:resync ;
    sh:node sc-sh:ResyncShape ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] .

sc-sh:ParticipantProjectionResponseShape
  a sh:NodeShape ;
  sh:targetClass sc:ParticipantProjectionResponse ;
  sh:property [
    sh:path sc:envelopeType ;
    sh:hasValue "stagecraft.participant-projection.response.v1" ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [
    sh:path sc:participant ;
    sh:nodeKind sh:IRI ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [
    sh:path sc:participantProjection ;
    sh:nodeKind sh:IRI ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [
    sh:path sc:projectionHistory ;
    sh:nodeKind sh:IRI ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [
    sh:path sc:projectionState ;
    sh:nodeKind sh:IRI ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [
    sh:path sc:projectionStateOrdinal ;
    sh:datatype xsd:nonNegativeInteger ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [
    sh:path sc:sourceProjection ;
    sh:node sc-sh:SourceProjectionShape ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [
    sh:path sc:visibleResources ;
    sh:nodeKind sh:IRI ;
    sh:minCount 1 ;
  ] ;
  sh:property [
    sh:path sc:resourceSummaries ;
    sh:node sc-sh:ResourceSummaryShape ;
  ] ;
  sh:property [
    sh:path sc:historyScope ;
    sh:maxCount 0 ;
    sh:message "ParticipantProjectionResponse carries resolved current state, not a request history scope." ;
  ] ;
  sh:property [
    sh:path sc:branchScope ;
    sh:maxCount 0 ;
    sh:message "ParticipantProjectionResponse carries resolved current state, not a request branch scope." ;
  ] ;
  sh:property [
    sh:path sc:temporalScope ;
    sh:maxCount 0 ;
    sh:message "ParticipantProjectionResponse v1 does not carry temporal axes." ;
  ] ;
  sh:property [
    sh:path sc:acceptanceInterval ;
    sh:maxCount 0 ;
    sh:message "ParticipantProjectionResponse v1 does not expose acceptance intervals." ;
  ] ;
  sh:property [
    sh:path sc:applicabilityInterval ;
    sh:maxCount 0 ;
    sh:message "ParticipantProjectionResponse v1 does not expose applicability intervals." ;
  ] ;
  sh:property [
    sh:path sc:requestedOperation ;
    sh:maxCount 0 ;
    sh:message "ParticipantProjectionResponse is a read envelope, not an operation request." ;
  ] ;
  sh:property [
    sh:path sc:execute ;
    sh:maxCount 0 ;
    sh:message "ParticipantProjectionResponse is a read envelope, not an executable operation." ;
  ] ;
  sh:property [
    sh:path sc:wouldProduce ;
    sh:maxCount 0 ;
    sh:message "ParticipantProjectionResponse must not preview authority-produced resources." ;
  ] ;
  sh:property [
    sh:path sc:producedResources ;
    sh:maxCount 0 ;
    sh:message "ParticipantProjectionResponse must not claim produced resources." ;
  ] ;
  sh:property [
    sh:path sc:authorityRecord ;
    sh:maxCount 0 ;
    sh:message "ParticipantProjectionResponse exposes authority records only as visible resource pointers." ;
  ] ;
  sh:property [
    sh:path sc:committedEvent ;
    sh:maxCount 0 ;
    sh:message "ParticipantProjectionResponse exposes committed events only as visible resource pointers." ;
  ] ;
  sh:property [
    sh:path sc:commitCertificate ;
    sh:maxCount 0 ;
    sh:message "ParticipantProjectionResponse exposes commit certificates only as visible resource pointers." ;
  ] ;
  sh:property [
    sh:path sc:stateMutation ;
    sh:maxCount 0 ;
    sh:message "ParticipantProjectionResponse exposes state mutations only as visible resource pointers." ;
  ] .

sc-sh:ChatContributionShape
  a sh:NodeShape ;
  sh:targetClass sc:ChatContribution ;
  sh:property [
    sh:path sc:envelopeType ;
    sh:hasValue "stagecraft.chat.contribution.v1" ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [
    sh:path sc:session ;
    sh:nodeKind sh:IRI ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [
    sh:path sc:conversation ;
    sh:nodeKind sh:IRI ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [
    sh:path sc:submittedByParticipant ;
    sh:nodeKind sh:IRI ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [
    sh:path sc:speakingContext ;
    sh:node sc-sh:SpeakingContextShape ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [
    sh:path sc:sourceProjection ;
    sh:node sc-sh:SourceProjectionShape ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [
    sh:path sc:relatesTo ;
    sh:nodeKind sh:IRI ;
    sh:minCount 1 ;
  ] ;
  sh:property [
    sh:path sc:historyScope ;
    sh:maxCount 0 ;
    sh:message "ChatContribution targets session/conversation; authority resolves history scope later." ;
  ] ;
  sh:property [
    sh:path sc:branchScope ;
    sh:maxCount 0 ;
    sh:message "ChatContribution targets session/conversation; authority resolves branch scope later." ;
  ] ;
  sh:property [
    sh:path sc:temporalScope ;
    sh:maxCount 0 ;
    sh:message "ChatContribution targets session/conversation; authority resolves temporal scope later." ;
  ] ;
  sh:property [
    sh:path sc:wouldProduce ;
    sh:maxCount 0 ;
    sh:message "ChatContribution must not claim authority-produced resources." ;
  ] ;
  sh:property [
    sh:path sc:producedResources ;
    sh:maxCount 0 ;
    sh:message "ChatContribution must not claim authority-produced resources." ;
  ] ;
  sh:property [
    sh:path sc:authorityRecord ;
    sh:maxCount 0 ;
    sh:message "ChatContribution must not claim authority-produced resources." ;
  ] ;
  sh:property [
    sh:path sc:committedEvent ;
    sh:maxCount 0 ;
    sh:message "ChatContribution must not claim authority-produced resources." ;
  ] ;
  sh:property [
    sh:path sc:commitCertificate ;
    sh:maxCount 0 ;
    sh:message "ChatContribution must not claim authority-produced resources." ;
  ] ;
  sh:property [
    sh:path sc:stateMutation ;
    sh:maxCount 0 ;
    sh:message "ChatContribution must not claim authority-produced resources or accepted state mutation records." ;
  ] ;
  sh:property [
    sh:path sc:barred ;
    sh:maxCount 0 ;
    sh:message "ChatContribution must not carry accepted state facts." ;
  ] ;
  sh:property [
    sh:path sc:lastAuthorityRecord ;
    sh:maxCount 0 ;
    sh:message "ChatContribution must not carry accepted state provenance facts." ;
  ] .

sc-sh:AuthorityOperationShape
  a sh:NodeShape ;
  sh:targetClass sc:AuthorityOperation ;
  sh:property [
    sh:path sc:envelopeType ;
    sh:hasValue "stagecraft.authority.operation-request.v1" ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [
    sh:path sc:requestedByParticipant ;
    sh:nodeKind sh:IRI ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [
    sh:path sc:execute ;
    sh:hasValue false ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:message "AuthorityOperation fixture is a preview request and must keep execute false." ;
  ] ;
  sh:property [
    sh:path sc:historyScope ;
    sh:nodeKind sh:IRI ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [
    sh:path sc:branchScope ;
    sh:nodeKind sh:IRI ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [
    sh:path sc:temporalScope ;
    sh:nodeKind sh:IRI ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [
    sh:path sc:inputs ;
    sh:node sc-sh:AuthorityInputsShape ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [
    sh:path sc:wouldProduce ;
    sh:node sc-sh:AuthorityWouldProduceShape ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [
    sh:path sc:barred ;
    sh:maxCount 0 ;
    sh:message "AuthorityOperation request must not embed accepted state facts." ;
  ] ;
  sh:property [
    sh:path sc:lastAuthorityRecord ;
    sh:maxCount 0 ;
    sh:message "AuthorityOperation request must not embed accepted state provenance facts." ;
  ] .

sc-sh:ActantIntentRecommendationRequestShape
  a sh:NodeShape ;
  sh:targetClass sc:ActantIntentRecommendationRequest ;
  sh:property [
    sh:path sc:envelopeType ;
    sh:hasValue "stagecraft.actant-intent-recommendation.request.v1" ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [
    sh:path sc:requestedBy ;
    sh:nodeKind sh:IRI ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [
    sh:path sc:requestedOperation ;
    sh:hasValue "reviewCandidateActantIntent" ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [
    sh:path sc:requestedFocus ;
    sh:hasValue "roleplayFit" ;
    sh:minCount 1 ;
  ] ;
  sh:property [
    sh:path sc:requestedFocus ;
    sh:hasValue "delegationScope" ;
    sh:minCount 1 ;
  ] ;
  sh:property [
    sh:path sc:intentBearingActant ;
    sh:nodeKind sh:IRI ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [
    sh:path sc:candidateActantIntent ;
    sh:nodeKind sh:IRI ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [
    sh:path sc:candidateSourceKind ;
    sh:hasValue "contribution" ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [
    sh:path sc:sourceArtifact ;
    sh:nodeKind sh:IRI ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [
    sh:path sc:sourceProjection ;
    sh:node sc-sh:SourceProjectionShape ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [
    sh:path sc:candidateProposedByParticipant ;
    sh:nodeKind sh:IRI ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [
    sh:path sc:roleplayer ;
    sh:nodeKind sh:IRI ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [
    sh:path sc:evidencePointers ;
    sh:nodeKind sh:IRI ;
    sh:minCount 1 ;
  ] ;
  sh:property [
    sh:path sc:authorityRecord ;
    sh:maxCount 0 ;
    sh:message "ActantIntentRecommendationRequest must not claim authority-produced resources." ;
  ] ;
  sh:property [
    sh:path sc:committedEvent ;
    sh:maxCount 0 ;
    sh:message "ActantIntentRecommendationRequest must not claim committed events." ;
  ] ;
  sh:property [
    sh:path sc:commitCertificate ;
    sh:maxCount 0 ;
    sh:message "ActantIntentRecommendationRequest must not claim commit certificates." ;
  ] ;
  sh:property [
    sh:path sc:stateMutation ;
    sh:maxCount 0 ;
    sh:message "ActantIntentRecommendationRequest must not claim state mutations." ;
  ] ;
  sh:property [
    sh:path sc:wouldProduce ;
    sh:maxCount 0 ;
    sh:message "ActantIntentRecommendationRequest must not preview authority-produced resources." ;
  ] ;
  sh:property [
    sh:path sc:producedResources ;
    sh:maxCount 0 ;
    sh:message "ActantIntentRecommendationRequest must not claim produced resources." ;
  ] ;
  sh:property [
    sh:path sc:barred ;
    sh:maxCount 0 ;
    sh:message "ActantIntentRecommendationRequest must not carry accepted state facts." ;
  ] ;
  sh:property [
    sh:path sc:lastAuthorityRecord ;
    sh:maxCount 0 ;
    sh:message "ActantIntentRecommendationRequest must not carry accepted state provenance facts." ;
  ] .

sc-sh:ActantIntentRecommendationShape
  a sh:NodeShape ;
  sh:targetClass sc:ActantIntentRecommendation ;
  sh:property [
    sh:path sc:envelopeType ;
    sh:hasValue "stagecraft.actant-intent-recommendation.v1" ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [
    sh:path sc:respondsTo ;
    sh:nodeKind sh:IRI ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [
    sh:path sc:producedByParticipant ;
    sh:nodeKind sh:IRI ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [
    sh:path sc:recommendationDisposition ;
    sh:in (
      "candidateRecommended"
      "usableAsSubmitted"
      "needsClarification"
      "deferUntilTurn"
      "reviseBeforeUse"
      "blockIntent"
      "escalateToGM"
    ) ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [
    sh:path sc:recommendedActantIntent ;
    sh:nodeKind sh:IRI ;
    sh:maxCount 1 ;
  ] ;
  sh:property [
    sh:path sc:reasonSummary ;
    sh:datatype xsd:string ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [
    sh:path sc:confidenceLevel ;
    sh:in (
      "low"
      "medium"
      "high"
      "unknown"
    ) ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [
    sh:path sc:evidencePointers ;
    sh:nodeKind sh:IRI ;
    sh:minCount 1 ;
  ] ;
  sh:property [
    sh:path sc:suggestedOversightText ;
    sh:datatype xsd:string ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [
    sh:path sc:producerProvenance ;
    sh:datatype xsd:string ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [
    sh:path sc:authorityRecord ;
    sh:maxCount 0 ;
    sh:message "ActantIntentRecommendation must not claim authority-produced resources." ;
  ] ;
  sh:property [
    sh:path sc:committedEvent ;
    sh:maxCount 0 ;
    sh:message "ActantIntentRecommendation must not claim committed events." ;
  ] ;
  sh:property [
    sh:path sc:commitCertificate ;
    sh:maxCount 0 ;
    sh:message "ActantIntentRecommendation must not claim commit certificates." ;
  ] ;
  sh:property [
    sh:path sc:stateMutation ;
    sh:maxCount 0 ;
    sh:message "ActantIntentRecommendation must not claim state mutations." ;
  ] ;
  sh:property [
    sh:path sc:wouldProduce ;
    sh:maxCount 0 ;
    sh:message "ActantIntentRecommendation must not preview authority-produced resources." ;
  ] ;
  sh:property [
    sh:path sc:producedResources ;
    sh:maxCount 0 ;
    sh:message "ActantIntentRecommendation must not claim produced resources." ;
  ] ;
  sh:property [
    sh:path sc:barred ;
    sh:maxCount 0 ;
    sh:message "ActantIntentRecommendation must not carry accepted state facts." ;
  ] ;
  sh:property [
    sh:path sc:lastAuthorityRecord ;
    sh:maxCount 0 ;
    sh:message "ActantIntentRecommendation must not carry accepted state provenance facts." ;
  ] .

sc-sh:SpeakingContextShape
  a sh:NodeShape ;
  sh:property [
    sh:path sc:speakingContextType ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [
    sh:path sc:speaker ;
    sh:nodeKind sh:IRI ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] .

sc-sh:SourceProjectionShape
  a sh:NodeShape ;
  sh:property [
    sh:path sc:observedProjectionState ;
    sh:nodeKind sh:IRI ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [
    sh:path sc:participantProjection ;
    sh:nodeKind sh:IRI ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] .

sc-sh:ResourcePointersShape
  a sh:NodeShape ;
  sh:property [
    sh:path sc:authorityRecord ;
    sh:nodeKind sh:IRI ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [
    sh:path sc:committedEvent ;
    sh:nodeKind sh:IRI ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [
    sh:path sc:commitCertificate ;
    sh:nodeKind sh:IRI ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [
    sh:path sc:projectionState ;
    sh:nodeKind sh:IRI ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [
    sh:path sc:stateMutation ;
    sh:nodeKind sh:IRI ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] .

sc-sh:ResourceSummaryShape
  a sh:NodeShape ;
  sh:property [
    sh:path sc:resource ;
    sh:nodeKind sh:IRI ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [
    sh:path sc:resourceClass ;
    sh:nodeKind sh:IRI ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [
    sh:path sc:label ;
    sh:datatype xsd:string ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [
    sh:path sc:summary ;
    sh:datatype xsd:string ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] .

sc-sh:ResyncShape
  a sh:NodeShape ;
  sh:property [
    sh:path sc:resyncMode ;
    sh:hasValue "read-projection-fixture" ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [
    sh:path sc:resyncState ;
    sh:nodeKind sh:IRI ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [
    sh:path sc:resyncPath ;
    sh:datatype xsd:string ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] .

sc-sh:AuthorityInputsShape
  a sh:NodeShape ;
  sh:property [
    sh:path sc:acceptedIntent ;
    sh:nodeKind sh:IRI ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [
    sh:path sc:proposedOutcome ;
    sh:nodeKind sh:IRI ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [
    sh:path sc:targetEntity ;
    sh:nodeKind sh:IRI ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [
    sh:path sc:consequence ;
    sh:nodeKind sh:IRI ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] .

sc-sh:AuthorityWouldProduceShape
  a sh:NodeShape ;
  sh:property [
    sh:path sc:authorityRecord ;
    sh:nodeKind sh:IRI ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [
    sh:path sc:committedEvent ;
    sh:nodeKind sh:IRI ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [
    sh:path sc:commitCertificate ;
    sh:nodeKind sh:IRI ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [
    sh:path sc:stateMutation ;
    sh:nodeKind sh:IRI ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] .
