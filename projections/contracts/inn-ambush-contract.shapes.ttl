sc-sh:D20TestWarrantDeclineRequestShape
  a sh:NodeShape ;
  sh:targetClass sc:D20TestWarrantDeclineRequest ;
  sh:property [
    sh:path sc:envelopeType ;
    sh:hasValue "stagecraft.d20-test-warrant.decline-request.v1" ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [
    sh:path sc:envelopeId ;
    sh:datatype xsd:string ;
    sh:minLength 1 ;
    sh:pattern "\\S" ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
