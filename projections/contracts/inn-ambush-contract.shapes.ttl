@prefix sc: <https://stagecraft.dev/ns/stagecraft/> .
@prefix scshape: <https://stagecraft.dev/ns/provisional/stagecraft-contract-shape#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

scshape:ProjectionNotificationShape
  a sh:NodeShape ;
  sh:targetClass sc:ProjectionNotification ;
  sh:property [
    sh:path sc:signal ;
    sh:hasValue "projection-ready" ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [
    sh:path sc:authorityRecord ;
    sh:nodeKind sh:IRI ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [
    sh:path sc:committedEvent ;
    sh:nodeKind sh:IRI ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [
    sh:path sc:commitCertificate ;
    sh:nodeKind sh:IRI ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [
    sh:path sc:projectionState ;
    sh:nodeKind sh:IRI ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [
    sh:path sc:stateMutation ;
    sh:nodeKind sh:IRI ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [
    sh:path sc:projectionPath ;
    sh:datatype xsd:string ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [
    sh:path sc:resync ;
    sh:node scshape:ResyncShape ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [
    sh:path sc:barred ;
    sh:maxCount 0 ;
    sh:message "ProjectionNotification must remain pointer-only and not carry accepted state facts." ;
  ] ;
  sh:property [
    sh:path sc:lastAuthorityRecord ;
    sh:maxCount 0 ;
    sh:message "ProjectionNotification must point to authority records without embedding accepted state provenance fields." ;
  ] .

scshape:ProjectionRequestShape
  a sh:NodeShape ;
  sh:targetClass sc:ProjectionRequest ;
  sh:property [
    sh:path sc:envelopeType ;
    sh:hasValue "stagecraft.projection.request.v1" ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [
    sh:path sc:requestedByParticipant ;
    sh:nodeKind sh:IRI ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [
    sh:path sc:projectionId ;
    sh:nodeKind sh:IRI ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [
    sh:path sc:historyScope ;
    sh:nodeKind sh:IRI ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [
    sh:path sc:branchScope ;
    sh:nodeKind sh:IRI ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [
    sh:path sc:temporalScope ;
    sh:nodeKind sh:IRI ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [
    sh:path sc:resourcePointers ;
    sh:node scshape:ResourcePointersShape ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [
    sh:path sc:resync ;
    sh:node scshape:ResyncShape ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] .

scshape:ChatContributionShape
  a sh:NodeShape ;
  sh:targetClass sc:ChatContribution ;
  sh:property [
    sh:path sc:envelopeType ;
    sh:hasValue "stagecraft.chat.contribution.v1" ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [
    sh:path sc:session ;
    sh:nodeKind sh:IRI ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [
    sh:path sc:conversation ;
    sh:nodeKind sh:IRI ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [
    sh:path sc:submittedByParticipant ;
    sh:nodeKind sh:IRI ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [
    sh:path sc:speakingContext ;
    sh:node scshape:SpeakingContextShape ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [
    sh:path sc:sourceProjection ;
    sh:node scshape:SourceProjectionShape ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [
    sh:path sc:relatesTo ;
    sh:nodeKind sh:IRI ;
    sh:minCount 1 ;
  ] ;
  sh:property [
    sh:path sc:historyScope ;
    sh:maxCount 0 ;
    sh:message "ChatContribution targets session/conversation; authority resolves history scope later." ;
  ] ;
  sh:property [
    sh:path sc:branchScope ;
    sh:maxCount 0 ;
    sh:message "ChatContribution targets session/conversation; authority resolves branch scope later." ;
  ] ;
  sh:property [
    sh:path sc:temporalScope ;
    sh:maxCount 0 ;
    sh:message "ChatContribution targets session/conversation; authority resolves temporal scope later." ;
  ] ;
  sh:property [
    sh:path sc:wouldProduce ;
    sh:maxCount 0 ;
    sh:message "ChatContribution must not claim authority-produced resources." ;
  ] ;
  sh:property [
    sh:path sc:producedResources ;
    sh:maxCount 0 ;
    sh:message "ChatContribution must not claim authority-produced resources." ;
  ] ;
  sh:property [
    sh:path sc:authorityRecord ;
    sh:maxCount 0 ;
    sh:message "ChatContribution must not claim authority-produced resources." ;
  ] ;
  sh:property [
    sh:path sc:committedEvent ;
    sh:maxCount 0 ;
    sh:message "ChatContribution must not claim authority-produced resources." ;
  ] ;
  sh:property [
    sh:path sc:commitCertificate ;
    sh:maxCount 0 ;
    sh:message "ChatContribution must not claim authority-produced resources." ;
  ] ;
  sh:property [
    sh:path sc:stateMutation ;
    sh:maxCount 0 ;
    sh:message "ChatContribution must not claim authority-produced resources or accepted state mutation records." ;
  ] ;
  sh:property [
    sh:path sc:barred ;
    sh:maxCount 0 ;
    sh:message "ChatContribution must not carry accepted state facts." ;
  ] ;
  sh:property [
    sh:path sc:lastAuthorityRecord ;
    sh:maxCount 0 ;
    sh:message "ChatContribution must not carry accepted state provenance facts." ;
  ] .

scshape:AuthorityOperationShape
  a sh:NodeShape ;
  sh:targetClass sc:AuthorityOperation ;
  sh:property [
    sh:path sc:envelopeType ;
    sh:hasValue "stagecraft.authority.operation-request.v1" ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [
    sh:path sc:requestedByParticipant ;
    sh:nodeKind sh:IRI ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [
    sh:path sc:execute ;
    sh:hasValue false ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:message "AuthorityOperation fixture is a preview request and must keep execute false." ;
  ] ;
  sh:property [
    sh:path sc:historyScope ;
    sh:nodeKind sh:IRI ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [
    sh:path sc:branchScope ;
    sh:nodeKind sh:IRI ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [
    sh:path sc:temporalScope ;
    sh:nodeKind sh:IRI ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [
    sh:path sc:inputs ;
    sh:node scshape:AuthorityInputsShape ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [
    sh:path sc:wouldProduce ;
    sh:node scshape:AuthorityWouldProduceShape ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [
    sh:path sc:barred ;
    sh:maxCount 0 ;
    sh:message "AuthorityOperation request must not embed accepted state facts." ;
  ] ;
  sh:property [
    sh:path sc:lastAuthorityRecord ;
    sh:maxCount 0 ;
    sh:message "AuthorityOperation request must not embed accepted state provenance facts." ;
  ] .

scshape:SpeakingContextShape
  a sh:NodeShape ;
  sh:property [
    sh:path sc:speakingContextType ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [
    sh:path sc:speaker ;
    sh:nodeKind sh:IRI ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] .

scshape:SourceProjectionShape
  a sh:NodeShape ;
  sh:property [
    sh:path sc:projectionState ;
    sh:nodeKind sh:IRI ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [
    sh:path sc:participantProjection ;
    sh:nodeKind sh:IRI ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] .

scshape:ResourcePointersShape
  a sh:NodeShape ;
  sh:property [
    sh:path sc:authorityRecord ;
    sh:nodeKind sh:IRI ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [
    sh:path sc:committedEvent ;
    sh:nodeKind sh:IRI ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [
    sh:path sc:commitCertificate ;
    sh:nodeKind sh:IRI ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [
    sh:path sc:projectionState ;
    sh:nodeKind sh:IRI ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [
    sh:path sc:stateMutation ;
    sh:nodeKind sh:IRI ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] .

scshape:ResyncShape
  a sh:NodeShape ;
  sh:property [
    sh:path sc:resyncMode ;
    sh:hasValue "read-projection-fixture" ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [
    sh:path sc:resyncState ;
    sh:nodeKind sh:IRI ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [
    sh:path sc:resyncPath ;
    sh:datatype xsd:string ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] .

scshape:AuthorityInputsShape
  a sh:NodeShape ;
  sh:property [
    sh:path sc:acceptedIntent ;
    sh:nodeKind sh:IRI ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [
    sh:path sc:proposedOutcome ;
    sh:nodeKind sh:IRI ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [
    sh:path sc:targetEntity ;
    sh:nodeKind sh:IRI ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [
    sh:path sc:consequence ;
    sh:nodeKind sh:IRI ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] .

scshape:AuthorityWouldProduceShape
  a sh:NodeShape ;
  sh:property [
    sh:path sc:authorityRecord ;
    sh:nodeKind sh:IRI ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [
    sh:path sc:committedEvent ;
    sh:nodeKind sh:IRI ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [
    sh:path sc:commitCertificate ;
    sh:nodeKind sh:IRI ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [
    sh:path sc:stateMutation ;
    sh:nodeKind sh:IRI ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] .
