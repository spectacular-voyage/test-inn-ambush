    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [
    sh:path dyn:consequenceDescription ;
    sh:datatype xsd:string ;
    sh:minLength 1 ;
    sh:pattern "\\S" ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [
    sh:path sc:barred ;
    sh:datatype xsd:boolean ;
    sh:minCount 1 ;
