@prefix sc: <https://spectacular-voyage.github.io/stagecraft/ontology/> .
@prefix sc-sh: <https://spectacular-voyage.github.io/stagecraft/shacl/> .
@prefix dyn: <https://spectacular-voyage.github.io/stagecraft/ontology/dynamis/> .
@prefix perceptio: <https://spectacular-voyage.github.io/stagecraft/ontology/perceptio/> .
@prefix possessio: <https://spectacular-voyage.github.io/stagecraft/ontology/possessio/> .
@prefix roleosum: <https://spectacular-voyage.github.io/stagecraft/ontology/roleosum/> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix time: <http://www.w3.org/2006/time#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

sc-sh:ProjectionNotificationEnvelopeShape
  a sh:NodeShape ;
  sh:targetSubjectsOf sc:eventKind ;
  sh:property [
    sh:path sc:cloudEventSpecVersion ;
    sh:hasValue "1.0" ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [
    sh:path sc:envelopeType ;
    sh:hasValue "stagecraft.projection.ready.v1" ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [
    sh:path sc:eventKind ;
    sh:in (
      "projection-ready"
      "time-advanced"
    ) ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [
    sh:path sc:dataContentType ;
    sh:hasValue "application/ld+json" ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] .

sc-sh:ProjectionNotificationShape
  a sh:NodeShape ;
  sh:targetClass sc:ProjectionNotification ;
  sh:property [
    sh:path sc:signal ;
    sh:hasValue "projection-ready" ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [
    sh:path sc:authorityRecord ;
    sh:nodeKind sh:IRI ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [
    sh:path sc:committedEvent ;
    sh:nodeKind sh:IRI ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [
    sh:path sc:commitCertificate ;
    sh:nodeKind sh:IRI ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [
    sh:path sc:projectionState ;
    sh:nodeKind sh:IRI ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [
    sh:path sc:stateMutation ;
    sh:nodeKind sh:IRI ;
    sh:maxCount 1 ;
  ] ;
  sh:property [
    sh:path sc:projectionPath ;
    sh:datatype xsd:string ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [
    sh:path sc:resync ;
    sh:node sc-sh:ResyncShape ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [
    sh:path sc:barred ;
    sh:maxCount 0 ;
    sh:message "ProjectionNotification must remain pointer-only and not carry accepted state facts." ;
  ] ;
  sh:property [
    sh:path sc:lastAuthorityRecord ;
    sh:maxCount 0 ;
    sh:message "ProjectionNotification must point to authority records without embedding accepted state provenance fields." ;
  ] .

sc-sh:ProjectionRequestShape
  a sh:NodeShape ;
  sh:targetClass sc:ProjectionRequest ;
  sh:property [
    sh:path sc:envelopeType ;
    sh:hasValue "stagecraft.projection.request.v1" ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [
    sh:path sc:requestedByParticipant ;
    sh:nodeKind sh:IRI ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [
    sh:path sc:projectionId ;
    sh:nodeKind sh:IRI ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [
    sh:path sc:historyScope ;
    sh:nodeKind sh:IRI ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [
    sh:path sc:branchScope ;
    sh:nodeKind sh:IRI ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [
    sh:path sc:temporalScope ;
    sh:nodeKind sh:IRI ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [
    sh:path sc:resourcePointers ;
    sh:node sc-sh:ResourcePointersShape ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [
    sh:path sc:resync ;
    sh:node sc-sh:ResyncShape ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] .

sc-sh:ParticipantProjectionResponseShape
  a sh:NodeShape ;
  sh:targetClass sc:ParticipantProjectionResponse ;
  sh:property [
    sh:path sc:envelopeType ;
    sh:hasValue "stagecraft.participant-projection.response.v1" ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [
    sh:path sc:participant ;
    sh:nodeKind sh:IRI ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [
    sh:path sc:participantProjection ;
    sh:nodeKind sh:IRI ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [
    sh:path sc:projectionHistory ;
    sh:nodeKind sh:IRI ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [
    sh:path sc:projectionState ;
    sh:nodeKind sh:IRI ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [
    sh:path sc:projectionStateOrdinal ;
    sh:datatype xsd:nonNegativeInteger ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [
    sh:path sc:projectionTimeline ;
    sh:node sc-sh:ProjectionTimelineShape ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [
    sh:path sc:sourceProjection ;
    sh:node sc-sh:SourceProjectionShape ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [
    sh:path sc:authenticatedActor ;
    sh:node sc-sh:ProjectionActorShape ;
    sh:maxCount 1 ;
  ] ;
  sh:property [
    sh:path sc:appliedPerspective ;
    sh:node sc-sh:AppliedPerspectiveShape ;
    sh:maxCount 1 ;
  ] ;
  sh:property [
    sh:path sc:visibleResources ;
    sh:nodeKind sh:IRI ;
    sh:minCount 1 ;
  ] ;
  sh:property [
    sh:path sc:resourceSummaries ;
    sh:node sc-sh:ResourceSummaryShape ;
  ] ;
  sh:property [
    sh:path sc:historyScope ;
    sh:maxCount 0 ;
    sh:message "ParticipantProjectionResponse carries resolved current state, not a request history scope." ;
  ] ;
  sh:property [
    sh:path sc:branchScope ;
    sh:maxCount 0 ;
    sh:message "ParticipantProjectionResponse carries resolved current state, not a request branch scope." ;
  ] ;
  sh:property [
    sh:path sc:temporalScope ;
    sh:maxCount 0 ;
    sh:message "ParticipantProjectionResponse v1 does not carry temporal axes." ;
  ] ;
  sh:property [
    sh:path sc:acceptanceInterval ;
    sh:maxCount 0 ;
    sh:message "ParticipantProjectionResponse v1 does not expose acceptance intervals." ;
  ] ;
  sh:property [
    sh:path sc:applicabilityInterval ;
    sh:maxCount 0 ;
    sh:message "ParticipantProjectionResponse v1 does not expose applicability intervals." ;
  ] ;
  sh:property [
    sh:path sc:requestedOperation ;
    sh:maxCount 0 ;
    sh:message "ParticipantProjectionResponse is a read envelope, not an operation request." ;
  ] ;
  sh:property [
    sh:path sc:execute ;
    sh:maxCount 0 ;
    sh:message "ParticipantProjectionResponse is a read envelope, not an executable operation." ;
  ] ;
  sh:property [
    sh:path sc:wouldProduce ;
    sh:maxCount 0 ;
    sh:message "ParticipantProjectionResponse must not preview authority-produced resources." ;
  ] ;
  sh:property [
    sh:path sc:producedResources ;
    sh:maxCount 0 ;
    sh:message "ParticipantProjectionResponse must not claim produced resources." ;
  ] ;
  sh:property [
    sh:path sc:authorityRecord ;
    sh:maxCount 0 ;
    sh:message "ParticipantProjectionResponse exposes authority records only as visible resource pointers." ;
  ] ;
  sh:property [
    sh:path sc:committedEvent ;
    sh:maxCount 0 ;
    sh:message "ParticipantProjectionResponse exposes committed events only as visible resource pointers." ;
  ] ;
  sh:property [
    sh:path sc:commitCertificate ;
    sh:maxCount 0 ;
    sh:message "ParticipantProjectionResponse exposes commit certificates only as visible resource pointers." ;
  ] ;
  sh:property [
    sh:path sc:stateMutation ;
    sh:maxCount 0 ;
    sh:message "ParticipantProjectionResponse exposes state mutations only as visible resource pointers." ;
  ] .

sc-sh:ChatContributionShape
  a sh:NodeShape ;
  sh:targetClass sc:ChatContribution ;
  sh:property [
    sh:path sc:envelopeType ;
    sh:hasValue "stagecraft.chat.contribution.v1" ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [
    sh:path sc:session ;
    sh:nodeKind sh:IRI ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [
    sh:path sc:conversation ;
    sh:nodeKind sh:IRI ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [
    sh:path sc:submittedByParticipant ;
    sh:nodeKind sh:IRI ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [
    sh:path sc:speakingContext ;
    sh:node sc-sh:SpeakingContextShape ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [
    sh:path sc:sourceProjection ;
    sh:node sc-sh:SourceProjectionShape ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [
    sh:path sc:body ;
    sh:datatype xsd:string ;
    sh:minLength 1 ;
    sh:pattern "\\S" ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [
    sh:path sc:relatesTo ;
    sh:nodeKind sh:IRI ;
    sh:minCount 1 ;
  ] ;
  sh:property [
    sh:path sc:historyScope ;
    sh:maxCount 0 ;
    sh:message "ChatContribution targets session/conversation; authority resolves history scope later." ;
  ] ;
  sh:property [
    sh:path sc:branchScope ;
    sh:maxCount 0 ;
    sh:message "ChatContribution targets session/conversation; authority resolves branch scope later." ;
  ] ;
  sh:property [
    sh:path sc:temporalScope ;
    sh:maxCount 0 ;
    sh:message "ChatContribution targets session/conversation; authority resolves temporal scope later." ;
  ] ;
  sh:property [
    sh:path sc:wouldProduce ;
    sh:maxCount 0 ;
    sh:message "ChatContribution must not claim authority-produced resources." ;
  ] ;
  sh:property [
    sh:path sc:producedResources ;
    sh:maxCount 0 ;
    sh:message "ChatContribution must not claim authority-produced resources." ;
  ] ;
  sh:property [
    sh:path sc:authorityRecord ;
    sh:maxCount 0 ;
    sh:message "ChatContribution must not claim authority-produced resources." ;
  ] ;
  sh:property [
    sh:path sc:committedEvent ;
    sh:maxCount 0 ;
    sh:message "ChatContribution must not claim authority-produced resources." ;
  ] ;
  sh:property [
    sh:path sc:commitCertificate ;
    sh:maxCount 0 ;
    sh:message "ChatContribution must not claim authority-produced resources." ;
  ] ;
  sh:property [
    sh:path sc:stateMutation ;
    sh:maxCount 0 ;
    sh:message "ChatContribution must not claim authority-produced resources or accepted state mutation records." ;
  ] ;
  sh:property [
    sh:path sc:barred ;
    sh:maxCount 0 ;
    sh:message "ChatContribution must not carry accepted state facts." ;
  ] ;
  sh:property [
    sh:path sc:lastAuthorityRecord ;
    sh:maxCount 0 ;
    sh:message "ChatContribution must not carry accepted state provenance facts." ;
  ] .

sc-sh:CheckpointRequestShape
  a sh:NodeShape ;
  sh:targetClass sc:CheckpointRequest ;
  sh:property [
    sh:path sc:envelopeType ;
    sh:hasValue "stagecraft.checkpoint.request.v1" ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [
    sh:path sc:envelopeId ;
    sh:datatype xsd:string ;
    sh:minLength 1 ;
    sh:pattern "\\S" ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [
    sh:path sc:requestedByParticipant ;
    sh:nodeKind sh:IRI ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [
    sh:path sc:label ;
    sh:datatype xsd:string ;
    sh:minLength 1 ;
    sh:pattern "\\S" ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [
    sh:path sc:sourceProjection ;
    sh:node sc-sh:SourceProjectionShape ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] .

sc-sh:D20RollModifierInputShape
  a sh:NodeShape ;
  sh:property [
    sh:path dyn:modifierKind ;
    sh:in (
      "ability"
      "proficiency"
      "circumstance"
    ) ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [
    sh:path dyn:modifierSource ;
    sh:nodeKind sh:IRI ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [
    sh:path dyn:modifierValue ;
    sh:datatype xsd:integer ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] .

sc-sh:D20TestRequestShape
  a sh:NodeShape ;
  sh:targetClass sc:D20TestRequest ;
  sh:property [
    sh:path sc:envelopeType ;
    sh:hasValue "stagecraft.d20-test.request.v1" ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [
    sh:path sc:envelopeId ;
    sh:datatype xsd:string ;
    sh:minLength 1 ;
    sh:pattern "\\S" ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [
    sh:path sc:requestedByParticipant ;
    sh:nodeKind sh:IRI ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [
    sh:path sc:speakingContext ;
    sh:node sc-sh:SpeakingContextShape ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [
    sh:path dyn:warrantedActor ;
    sh:nodeKind sh:IRI ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [
    sh:path dyn:warrantedTestType ;
    sh:nodeKind sh:IRI ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [
    sh:path dyn:targetNumber ;
    sh:datatype xsd:integer ;
    sh:maxCount 1 ;
  ] ;
  sh:property [
    sh:path dyn:resolvesWarrant ;
    sh:nodeKind sh:IRI ;
    sh:maxCount 1 ;
  ] ;
  sh:property [
    sh:path dyn:diceExpression ;
    sh:datatype xsd:string ;
    sh:minLength 1 ;
    sh:pattern "\\S" ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [
    sh:path dyn:rollModifier ;
    sh:node sc-sh:D20RollModifierInputShape ;
  ] ;
  sh:property [
    sh:path dyn:consequenceDescription ;
    sh:datatype xsd:string ;
    sh:minLength 1 ;
    sh:pattern "\\S" ;
    sh:maxCount 1 ;
  ] ;
  sh:property [
    sh:path sc:sourceProjection ;
    sh:node sc-sh:SourceProjectionShape ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [
    sh:path sc:createdAt ;
    sh:datatype xsd:dateTime ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] .

sc-sh:TableRollRequestShape
  a sh:NodeShape ;
  sh:targetClass sc:TableRollRequest ;
  sh:property [
    sh:path sc:envelopeType ;
    sh:hasValue "stagecraft.table-roll.request.v1" ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [
    sh:path sc:envelopeId ;
    sh:datatype xsd:string ;
    sh:minLength 1 ;
    sh:pattern "\\S" ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [
    sh:path sc:requestedByParticipant ;
    sh:nodeKind sh:IRI ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [
    sh:path dyn:diceExpression ;
    sh:datatype xsd:string ;
    sh:minLength 1 ;
    sh:pattern "\\S" ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [
    sh:path sc:label ;
    sh:datatype xsd:string ;
    sh:minLength 1 ;
    sh:pattern "\\S" ;
    sh:maxCount 1 ;
  ] ;
  sh:property [
    sh:path sc:deliveredTo ;
    sh:nodeKind sh:IRI ;
  ] ;
  sh:property [
    sh:path sc:sourceProjection ;
    sh:node sc-sh:SourceProjectionShape ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [
    sh:path sc:createdAt ;
    sh:datatype xsd:dateTime ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [
    sh:path dyn:warrantedActor ;
    sh:maxCount 0 ;
    sh:message "TableRollRequest is table-layer dice evidence and must not name an actant." ;
  ] ;
  sh:property [
    sh:path dyn:warrantedTestType ;
    sh:maxCount 0 ;
    sh:message "TableRollRequest is table-layer dice evidence and must not name a D20 test type." ;
  ] ;
  sh:property [
    sh:path dyn:targetNumber ;
    sh:maxCount 0 ;
    sh:message "TableRollRequest is table-layer dice evidence and must not carry a target number." ;
  ] ;
  sh:property [
    sh:path dyn:resolvesWarrant ;
    sh:maxCount 0 ;
    sh:message "TableRollRequest cannot resolve a warrant; warrants require character context." ;
  ] ;
  sh:property [
    sh:path dyn:mechanicalResult ;
    sh:maxCount 0 ;
    sh:message "TableRollRequest is evidence only and must not claim a success judgment." ;
  ] ;
  sh:property [
    sh:path dyn:adjudicatedResult ;
    sh:maxCount 0 ;
    sh:message "TableRollRequest is evidence only and must not claim an adjudicated result." ;
  ] .

