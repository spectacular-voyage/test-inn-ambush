  sh:property [
    sh:path sc:createdAt ;
    sh:datatype xsd:dateTime ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [
    sh:path sc:stateMutation ;
    sh:maxCount 0 ;
