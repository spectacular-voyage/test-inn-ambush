{
  "@context": {
    "@version": 1.1,
    "@vocab": "https://spectacular-voyage.github.io/stagecraft/ontology/",
    "sc": "https://spectacular-voyage.github.io/stagecraft/ontology/",
    "sflo": "https://semantic-flow.github.io/sflo/ontology/",
    "dcterms": "http://purl.org/dc/terms/",
    "owlTime": "http://www.w3.org/2006/time#",
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "type": "sc:envelopeType",
    "id": "sc:envelopeId",
    "specversion": "sc:cloudEventSpecVersion",
    "source": "sc:cloudEventSource",
    "eventKind": "sc:eventKind",
    "time": {
      "@id": "sc:cloudEventTime",
      "@type": "xsd:dateTime"
    },
    "subject": {
      "@id": "sc:subject",
      "@type": "@id"
    },
    "predicate": {
      "@type": "@id"
    },
    "object": {
      "@id": "sc:object"
    },
    "datacontenttype": "sc:dataContentType",
    "session": {
      "@type": "@id"
    },
    "conversation": {
      "@type": "@id"
    },
    "references": {
      "@id": "dcterms:references",
      "@type": "@id"
    },
    "authorizedByAuthorityRecord": {
      "@type": "@id"
    },
    "basedOnHistory": {
      "@type": "@id"
    },
    "deliveredTo": {
      "@type": "@id"
    },
    "spokenByActant": {
      "@type": "@id"
    },
    "spokenByParticipant": {
      "@type": "@id"
    },
    "speechKind": "sc:speechKind",
    "submittedByParticipant": {
      "@type": "@id"
    },
    "requestedByParticipant": {
      "@type": "@id"
    },
    "participant": {
      "@id": "sc:participant",
      "@type": "@id"
    },
    "requestedBy": {
      "@type": "@id"
    },
    "respondsTo": {
      "@type": "@id"
    },
    "producedByParticipant": {
      "@type": "@id"
    },
    "projectionId": {
      "@type": "@id"
    },
    "historyScope": {
      "@type": "@id"
    },
    "branchScope": {
      "@type": "@id"
    },
    "temporalScope": {
      "@type": "@id"
    },
    "speakingContext": {
      "@id": "sc:speakingContext",
      "@context": {
        "type": "sc:speakingContextType",
        "speaker": {
          "@type": "@id"
        },
        "suggestedTo": {
          "@type": "@id"
        },
        "actant": {
          "@type": "@id"
        }
      }
    },
    "barred": {
      "@type": "xsd:boolean"
    },
    "acceptedFrom": {
      "@type": "xsd:dateTime"
    },
    "acceptedUntil": {
      "@type": "xsd:dateTime"
    },
    "applicableDuring": {
      "@type": "@id"
    },
    "applicableFrom": {
      "@type": "@id"
    },
    "applicableUntil": {
      "@type": "@id"
    },
    "applicableAfter": {
      "@type": "@id"
    },
    "applicableBefore": {
      "@type": "@id"
    },
    "hasBeginning": {
      "@id": "owlTime:hasBeginning",
      "@type": "@id"
    },
    "hasEnd": {
      "@id": "owlTime:hasEnd",
      "@type": "@id"
    },
    "clockOffsetSeconds": {
      "@type": "xsd:decimal"
    },
    "advancesClockEverySeconds": {
      "@type": "xsd:decimal"
    },
    "clockPrecision": "sc:clockPrecision",
    "usesWorldTimeAxis": {
      "@type": "@id"
    },
    "onWorldTimeAxis": {
      "@type": "@id"
    },
    "startsAtClockAnchor": {
      "@type": "@id"
    },
    "groundsTemporalAnchor": {
      "@type": "@id"
    },
    "groundedToClockAnchor": {
      "@type": "@id"
    },
    "advancesWorldTimeTo": {
      "@type": "@id"
    },
    "containedIn": {
      "@type": "@id"
    },
    "adjacentTo": {
      "@type": "@id"
    },
    "locatedIn": {
      "@type": "@id"
    },
    "movesActant": {
      "@type": "@id"
    },
    "fromPlace": {
      "@type": "@id"
    },
    "toPlace": {
      "@type": "@id"
    },
    "lastAuthorityRecord": {
      "@type": "@id"
    },
    "projectionHistory": {
      "@id": "sc:projectionHistory",
      "@type": "@id"
    },
    "projectionState": {
      "@type": "@id"
    },
    "projectionStateOrdinal": {
      "@id": "sc:projectionStateOrdinal",
      "@type": "xsd:nonNegativeInteger"
    },
    "capturePolicy": "sc:capturePolicy",
    "timelineStateKind": "sc:timelineStateKind",
    "states": {
      "@id": "sc:projectionTimelineStates"
    },
    "checkpoint": {
      "@id": "sc:checkpoint",
      "@type": "@id"
    },
    "label": "sc:label",
    "previousProjectionState": {
      "@id": "sc:previousProjectionState",
      "@type": "@id"
    },
    "nextProjectionState": {
      "@id": "sc:nextProjectionState",
      "@type": "@id"
    },
    "sourceProjection": {
      "@id": "sc:sourceProjection",
      "@context": {
        "observedProjectionState": {
          "@id": "sc:observedProjectionState",
          "@type": "@id"
        },
        "participantProjection": {
          "@id": "sc:participantProjection",
          "@type": "@id"
        }
      }
    },
    "projectionTimeline": {
      "@id": "sc:projectionTimeline",
      "@context": {
        "capturePolicy": "sc:capturePolicy",
        "projectionHistory": {
          "@id": "sc:projectionHistory",
          "@type": "@id"
        },
        "states": {
          "@id": "sc:projectionTimelineStates",
          "@context": {
            "kind": "sc:timelineStateKind",
            "checkpoint": {
              "@id": "sc:checkpoint",
              "@type": "@id"
            },
            "label": "sc:label",
            "projectionState": {
              "@id": "sc:projectionState",
              "@type": "@id"
            },
            "projectionStateOrdinal": {
              "@id": "sc:projectionStateOrdinal",
              "@type": "xsd:nonNegativeInteger"
            },
            "previousProjectionState": {
              "@id": "sc:previousProjectionState",
              "@type": "@id"
            },
            "nextProjectionState": {
              "@id": "sc:nextProjectionState",
              "@type": "@id"
            }
          }
        }
      }
    },
    "observedProjectionState": {
      "@type": "@id"
    },
    "participantProjection": {
      "@type": "@id"
    },
    "authenticatedActor": {
      "@id": "sc:authenticatedActor",
      "@context": {
        "participant": {
          "@id": "sc:participant",
          "@type": "@id"
        },
        "participantProjection": {
          "@id": "sc:participantProjection",
          "@type": "@id"
        },
        "projectionAudience": "sc:projectionAudience"
      }
    },
    "appliedPerspective": {
      "@id": "sc:appliedPerspective",
      "@context": {
        "type": "sc:perspectiveType",
        "character": {
          "@id": "sc:perspectiveCharacter",
          "@type": "@id"
        },
        "characterKey": "sc:perspectiveCharacterKey",
        "characterLabel": "sc:perspectiveCharacterLabel",
        "participant": {
          "@id": "sc:participant",
          "@type": "@id"
        },
        "participantProjection": {
          "@id": "sc:participantProjection",
          "@type": "@id"
        },
        "projectionAudience": "sc:projectionAudience",
        "readSemantics": "sc:readSemantics"
      }
    },
    "relatesTo": {
      "@type": "@id"
    },
    "intentBearingActant": {
      "@type": "@id"
    },
    "candidateActantIntent": {
      "@type": "@id"
    },
    "sourceArtifact": {
      "@type": "@id"
    },
    "candidateProposedByParticipant": {
      "@type": "@id"
    },
    "roleplayer": {
      "@type": "@id"
    },
    "participantAimContext": {
      "@type": "@id"
    },
    "visibleResources": {
      "@type": "@id"
    },
    "resourceSummaries": {
      "@id": "sc:resourceSummaries",
      "@context": {
        "resource": {
          "@id": "sc:resource",
          "@type": "@id"
        },
        "resourceClass": {
          "@id": "sc:resourceClass",
          "@type": "@id"
        },
        "label": "sc:label",
        "summary": "sc:summary"
      }
    },
    "evidencePointers": {
      "@type": "@id"
    },
    "recommendedActantIntent": {
      "@type": "@id"
    },
    "requestedOperation": "sc:requestedOperation",
    "requestedFocus": "sc:requestedFocus",
    "candidateSourceKind": "sc:candidateSourceKind",
    "recommendationDisposition": "sc:recommendationDisposition",
    "reasonSummary": "sc:reasonSummary",
    "confidenceLevel": "sc:confidenceLevel",
    "suggestedOversightText": "sc:suggestedOversightText",
    "producerProvenance": "sc:producerProvenance",
    "createdAt": {
      "@type": "xsd:dateTime"
    },
    "requestedAt": {
      "@type": "xsd:dateTime"
    },
    "authorityRecord": {
      "@type": "@id"
    },
    "committedEvent": {
      "@type": "@id"
    },
    "commitCertificate": {
      "@type": "@id"
    },
    "stateMutation": {
      "@type": "@id"
    },
    "resync": {
      "@id": "sc:resync",
      "@context": {
        "mode": "sc:resyncMode",
        "state": {
          "@id": "sc:resyncState",
          "@type": "@id"
        },
        "path": "sc:resyncPath"
      }
    },
    "execute": {
      "@type": "xsd:boolean"
    },
    "acceptedIntent": {
      "@type": "@id"
    },
    "proposedOutcome": {
      "@type": "@id"
    },
    "targetEntity": {
      "@type": "@id"
    },
    "consequence": {
      "@type": "@id"
    }
  }
}
