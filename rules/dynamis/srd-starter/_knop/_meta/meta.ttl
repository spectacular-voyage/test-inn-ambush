@base <https://spectacular-voyage.github.io/test-inn-ambush/> .
@prefix sflo: <https://semantic-flow.github.io/sflo/ontology/> .

<rules/dynamis/srd-starter/_knop> a sflo:Knop ;
  sflo:designatorPath "rules/dynamis/srd-starter" ;
  sflo:hasWorkingKnopInventoryFile <rules/dynamis/srd-starter/_knop/_inventory/inventory.ttl> .
