<https://spectacular-voyage.github.io/test-inn-ambush/rules/dynamis/srd-5-2-1/spells>
  a dcat:Dataset ;
  dcterms:title "SRD 5.2.1 spell rules" ;
  dcterms:description "Curated spell records, class availability, schools, and damage or healing expression data extracted from the CC SRD 5.2.1 PDF. Spell effects remain prose/data and are not wired into ActionTypes." ;
  dcterms:created "2026-07-05"^^xsd:date ;
  dcterms:license <https://creativecommons.org/licenses/by/4.0/> ;
  dcterms:source <https://media.dndbeyond.com/compendium-images/srd/5.2/SRD_CC_v5.2.1.pdf> ;
  dcterms:rights "Includes material from System Reference Document 5.2.1 by Wizards of the Coast LLC, available under the Creative Commons Attribution 4.0 International License." ;
  dcat:distribution <https://spectacular-voyage.github.io/test-inn-ambush/rules/dynamis/srd-5-2-1/spells/spells-csv>,
    <https://spectacular-voyage.github.io/test-inn-ambush/rules/dynamis/srd-5-2-1/spells/schools-csv>,
    <https://spectacular-voyage.github.io/test-inn-ambush/rules/dynamis/srd-5-2-1/spells/spell-classes-csv>,
    <https://spectacular-voyage.github.io/test-inn-ambush/rules/dynamis/srd-5-2-1/spells/spell-expressions-csv>,
    <https://spectacular-voyage.github.io/test-inn-ambush/rules/dynamis/srd-5-2-1/spells/spells-csvw> .

