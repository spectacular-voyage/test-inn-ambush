<https://spectacular-voyage.github.io/test-inn-ambush/rules/dynamis/srd-5-2-1/weapons>
  a dcat:Dataset ;
  dcterms:title "SRD 5.2.1 weapon rules" ;
  dcterms:description "Curated weapon, weapon property, damage type, and item-to-attack-option data extracted from the CC SRD 5.2.1 PDF. Attack rows link to the D20 attack-roll family as data only." ;
  dcterms:created "2026-07-05"^^xsd:date ;
  dcterms:license <https://creativecommons.org/licenses/by/4.0/> ;
  dcterms:source <https://media.dndbeyond.com/compendium-images/srd/5.2/SRD_CC_v5.2.1.pdf> ;
  dcterms:rights "Includes material from System Reference Document 5.2.1 by Wizards of the Coast LLC, available under the Creative Commons Attribution 4.0 International License." ;
  dcat:distribution <https://spectacular-voyage.github.io/test-inn-ambush/rules/dynamis/srd-5-2-1/weapons/weapons-csv>,
    <https://spectacular-voyage.github.io/test-inn-ambush/rules/dynamis/srd-5-2-1/weapons/properties-csv>,
    <https://spectacular-voyage.github.io/test-inn-ambush/rules/dynamis/srd-5-2-1/weapons/damage-types-csv>,
    <https://spectacular-voyage.github.io/test-inn-ambush/rules/dynamis/srd-5-2-1/weapons/item-actions-csv>,
    <https://spectacular-voyage.github.io/test-inn-ambush/rules/dynamis/srd-5-2-1/weapons/weapons-csvw> .

