<https://spectacular-voyage.github.io/test-inn-ambush/rules/dynamis/srd-5-2-1/d20-test>
  a dcat:Dataset ;
  dcterms:title "SRD 5.2.1 D20 test rules" ;
  dcterms:description "Curated ability, skill, check, save, and attack-roll family data extracted from the CC SRD 5.2.1 PDF." ;
  dcterms:created "2026-07-05"^^xsd:date ;
  dcterms:license <https://creativecommons.org/licenses/by/4.0/> ;
  dcterms:source <https://media.dndbeyond.com/compendium-images/srd/5.2/SRD_CC_v5.2.1.pdf> ;
  dcterms:rights "Includes material from System Reference Document 5.2.1 by Wizards of the Coast LLC, available under the Creative Commons Attribution 4.0 International License." ;
  dcat:distribution <https://spectacular-voyage.github.io/test-inn-ambush/rules/dynamis/srd-5-2-1/d20-test/abilities-csv>,
    <https://spectacular-voyage.github.io/test-inn-ambush/rules/dynamis/srd-5-2-1/d20-test/skills-csv>,
    <https://spectacular-voyage.github.io/test-inn-ambush/rules/dynamis/srd-5-2-1/d20-test/test-types-csv>,
    <https://spectacular-voyage.github.io/test-inn-ambush/rules/dynamis/srd-5-2-1/d20-test/d20-csvw> .

<https://spectacular-voyage.github.io/test-inn-ambush/rules/dynamis/srd-5-2-1/d20-test/abilities-csv>
  a dcat:Distribution ;
  dcterms:title "SRD 5.2.1 abilities curated CSV" ;
  dcat:downloadURL <https://spectacular-voyage.github.io/test-inn-ambush/rules/dynamis/srd-5-2-1/d20-test/d20-test.abilities.csv> .

<https://spectacular-voyage.github.io/test-inn-ambush/rules/dynamis/srd-5-2-1/d20-test/skills-csv>
  a dcat:Distribution ;
  dcterms:title "SRD 5.2.1 skills curated CSV" ;
  dcat:downloadURL <https://spectacular-voyage.github.io/test-inn-ambush/rules/dynamis/srd-5-2-1/d20-test/d20-test.skills.csv> .

<https://spectacular-voyage.github.io/test-inn-ambush/rules/dynamis/srd-5-2-1/d20-test/test-types-csv>
  a dcat:Distribution ;
  dcterms:title "SRD 5.2.1 D20 test types curated CSV" ;
  dcat:downloadURL <https://spectacular-voyage.github.io/test-inn-ambush/rules/dynamis/srd-5-2-1/d20-test/d20-test.test-types.csv> .

<https://spectacular-voyage.github.io/test-inn-ambush/rules/dynamis/srd-5-2-1/d20-test/d20-csvw>
  a dcat:Distribution ;
  dcterms:title "SRD 5.2.1 D20 CSVW mapping" ;
  dcat:downloadURL <https://spectacular-voyage.github.io/test-inn-ambush/rules/dynamis/srd-5-2-1/d20-test/d20-test.csvw.json> .

dyn:D20TestWarrantedPreconditionAsk
  a dyn:SparqlAskPrecondition ;
  rdf:value "ASK { # Authority or a rule has warranted a D20 Test in the current circumstance. }" .

dyn:D20RollResultTemplate
  a dyn:ConsequenceTemplate ;
  rdf:value "Roll 1d20, apply the relevant ability modifier, proficiency if applicable, and circumstantial modifiers, then compare against the target number." .

dyn:AbilityCheck
  a dyn:D20TestType, dyn:ActionType, owl:Class ;
  dcterms:isPartOf <https://spectacular-voyage.github.io/test-inn-ambush/rules/dynamis/srd-5-2-1/d20-test> ;
  rdfs:label "Ability check" ;
  dyn:testTypeKey "ability-check" ;
  dyn:verbIri dyn:ability-check ;
  dyn:preconditionAsk dyn:D20TestWarrantedPreconditionAsk ;
  dyn:consequenceTemplate dyn:D20RollResultTemplate ;
  dyn:targetNumberName "Difficulty Class" ;
  dyn:mechanicalStatus "actiontype-family" ;
  dyn:sourceSection "Playing the Game: Ability Checks" ;
  dcterms:description "A creature uses talent and training to try to overcome a challenge when the outcome is uncertain and meaningful." .

dyn:SavingThrow
  a dyn:D20TestType, dyn:ActionType, owl:Class ;
  dcterms:isPartOf <https://spectacular-voyage.github.io/test-inn-ambush/rules/dynamis/srd-5-2-1/d20-test> ;
  rdfs:label "Saving throw" ;
  dyn:testTypeKey "saving-throw" ;
  dyn:verbIri dyn:saving-throw ;
  dyn:preconditionAsk dyn:D20TestWarrantedPreconditionAsk ;
  dyn:consequenceTemplate dyn:D20RollResultTemplate ;
  dyn:targetNumberName "Difficulty Class" ;
  dyn:mechanicalStatus "actiontype-family" ;
  dyn:sourceSection "Playing the Game: Saving Throws" ;
  dcterms:description "A creature attempts to evade or resist a threat when a rule requires a save." .

dyn:AttackRoll
  a dyn:D20TestType, dyn:ActionType, owl:Class ;
  dcterms:isPartOf <https://spectacular-voyage.github.io/test-inn-ambush/rules/dynamis/srd-5-2-1/d20-test> ;
  rdfs:label "Attack roll" ;
  dyn:testTypeKey "attack-roll" ;
  dyn:verbIri dyn:attack-roll ;
  dyn:preconditionAsk dyn:D20TestWarrantedPreconditionAsk ;
  dyn:consequenceTemplate dyn:D20RollResultTemplate ;
  dyn:targetNumberName "Armor Class" ;
  dyn:mechanicalStatus "actiontype-family" ;
  dyn:sourceSection "Playing the Game: Attack Rolls" ;
  dcterms:description "A roll determines whether an attack hits by comparing the total to Armor Class." .

dyn:Strength
  a dyn:AbilityScore, skos:Concept ;
