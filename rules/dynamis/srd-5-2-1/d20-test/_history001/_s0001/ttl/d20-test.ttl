  rdfs:label "Strength" ;
  dyn:abilityKey "strength" ;
  dyn:abilityCheckExample "Lift, push, pull, or break something" ;
  dyn:savingThrowExample "Physically resist direct force" ;
  dyn:sourceSection "Playing the Game: D20 Tests" .

