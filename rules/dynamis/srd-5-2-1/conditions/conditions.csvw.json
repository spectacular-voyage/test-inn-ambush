      { "name": "mechanicalStatus", "datatype": "string", "required": true },
      { "name": "adjudicationNote", "datatype": "string" },
      { "name": "sourceSection", "datatype": "string", "required": true }
    ],
    "primaryKey": ["conditionKey", "effectKey"],
