<https://spectacular-voyage.github.io/test-inn-ambush/rules/dynamis/srd-5-2-1/conditions/condition/blinded>
  a dyn:ConditionDefinition, skos:Concept ;
  dcterms:isPartOf <https://spectacular-voyage.github.io/test-inn-ambush/rules/dynamis/srd-5-2-1/conditions> ;
  rdfs:label "Blinded" ;
  dyn:conditionKey "blinded" ;
  dyn:sourceSection "Rules Glossary: Blinded [Condition]" ;
  dyn:hasConditionEffect <https://spectacular-voyage.github.io/test-inn-ambush/rules/dynamis/srd-5-2-1/conditions/condition/blinded/effect/cant-see>,
    <https://spectacular-voyage.github.io/test-inn-ambush/rules/dynamis/srd-5-2-1/conditions/condition/blinded/effect/attacks-affected> .

<https://spectacular-voyage.github.io/test-inn-ambush/rules/dynamis/srd-5-2-1/conditions/condition/blinded/effect/cant-see>
  a dyn:ConditionEffect, dyn:AffordanceMaskDefinition ;
  dcterms:isPartOf <https://spectacular-voyage.github.io/test-inn-ambush/rules/dynamis/srd-5-2-1/conditions/condition/blinded> ;
  rdfs:label "Can't See" ;
  rdf:value "You can't see and automatically fail any ability check that requires sight." ;
  dyn:effectKey "cant-see" ;
  dyn:effectKind "sensory-mask" ;
  dyn:mechanicalStatus "codified-mask" ;
  dyn:sourceSection "Rules Glossary: Blinded [Condition]" ;
  dyn:adjudicationNote "The ability-check auto-failure depends on whether a check requires sight; the mask records the sensory affordance only." ;
  dyn:masksActionType dyn:UseSight .

<https://spectacular-voyage.github.io/test-inn-ambush/rules/dynamis/srd-5-2-1/conditions/condition/blinded/effect/attacks-affected>
  a dyn:ConditionEffect ;
  dcterms:isPartOf <https://spectacular-voyage.github.io/test-inn-ambush/rules/dynamis/srd-5-2-1/conditions/condition/blinded> ;
  rdfs:label "Attacks Affected" ;
  rdf:value "Attack rolls against you have Advantage, and your attack rolls have Disadvantage." ;
  dyn:effectKey "attacks-affected" ;
  dyn:effectKind "d20-modifier" ;
  dyn:mechanicalStatus "structured-not-mask" ;
  dyn:sourceSection "Rules Glossary: Blinded [Condition]" ;
  dyn:adjudicationNote "Attack-roll advantage and disadvantage are roll modifiers, not action masks." .

<https://spectacular-voyage.github.io/test-inn-ambush/rules/dynamis/srd-5-2-1/conditions/condition/charmed>
  a dyn:ConditionDefinition, skos:Concept ;
  dcterms:isPartOf <https://spectacular-voyage.github.io/test-inn-ambush/rules/dynamis/srd-5-2-1/conditions> ;
  rdfs:label "Charmed" ;
  dyn:conditionKey "charmed" ;
  dyn:sourceSection "Rules Glossary: Charmed [Condition]" ;
  dyn:hasConditionEffect <https://spectacular-voyage.github.io/test-inn-ambush/rules/dynamis/srd-5-2-1/conditions/condition/charmed/effect/cant-harm-the-charmer>,
    <https://spectacular-voyage.github.io/test-inn-ambush/rules/dynamis/srd-5-2-1/conditions/condition/charmed/effect/social-advantage> .

<https://spectacular-voyage.github.io/test-inn-ambush/rules/dynamis/srd-5-2-1/conditions/condition/charmed/effect/cant-harm-the-charmer>
  a dyn:ConditionEffect, dyn:AffordanceMaskDefinition ;
  dcterms:isPartOf <https://spectacular-voyage.github.io/test-inn-ambush/rules/dynamis/srd-5-2-1/conditions/condition/charmed> ;
  rdfs:label "Can't Harm the Charmer" ;
  rdf:value "You can't attack the charmer or target the charmer with damaging abilities or magical effects." ;
  dyn:effectKey "cant-harm-the-charmer" ;
  dyn:effectKind "conditional-affordance-mask" ;
  dyn:mechanicalStatus "adjudication-scoped-mask" ;
  dyn:sourceSection "Rules Glossary: Charmed [Condition]" ;
  dyn:adjudicationNote "The mask is source-scoped to the charmer and does not prohibit harm against others." ;
  dyn:masksActionType dyn:HarmConditionSource .

<https://spectacular-voyage.github.io/test-inn-ambush/rules/dynamis/srd-5-2-1/conditions/condition/charmed/effect/social-advantage>
  a dyn:ConditionEffect ;
  dcterms:isPartOf <https://spectacular-voyage.github.io/test-inn-ambush/rules/dynamis/srd-5-2-1/conditions/condition/charmed> ;
  rdfs:label "Social Advantage" ;
  rdf:value "The charmer has Advantage on any ability check to interact with you socially." ;
  dyn:effectKey "social-advantage" ;
  dyn:effectKind "d20-modifier" ;
  dyn:mechanicalStatus "structured-not-mask" ;
  dyn:sourceSection "Rules Glossary: Charmed [Condition]" ;
  dyn:adjudicationNote "Social interaction advantage is a roll modifier, not an action mask." .

<https://spectacular-voyage.github.io/test-inn-ambush/rules/dynamis/srd-5-2-1/conditions/condition/deafened>
  a dyn:ConditionDefinition, skos:Concept ;
  dcterms:isPartOf <https://spectacular-voyage.github.io/test-inn-ambush/rules/dynamis/srd-5-2-1/conditions> ;
  rdfs:label "Deafened" ;
  dyn:conditionKey "deafened" ;
  dyn:sourceSection "Rules Glossary: Deafened [Condition]" ;
  dyn:hasConditionEffect <https://spectacular-voyage.github.io/test-inn-ambush/rules/dynamis/srd-5-2-1/conditions/condition/deafened/effect/cant-hear> .

<https://spectacular-voyage.github.io/test-inn-ambush/rules/dynamis/srd-5-2-1/conditions/condition/deafened/effect/cant-hear>
  a dyn:ConditionEffect, dyn:AffordanceMaskDefinition ;
  dcterms:isPartOf <https://spectacular-voyage.github.io/test-inn-ambush/rules/dynamis/srd-5-2-1/conditions/condition/deafened> ;
  rdfs:label "Can't Hear" ;
  rdf:value "You can't hear and automatically fail any ability check that requires hearing." ;
  dyn:effectKey "cant-hear" ;
  dyn:effectKind "sensory-mask" ;
  dyn:mechanicalStatus "codified-mask" ;
  dyn:sourceSection "Rules Glossary: Deafened [Condition]" ;
  dyn:adjudicationNote "The ability-check auto-failure depends on whether a check requires hearing; the mask records the sensory affordance only." ;
  dyn:masksActionType dyn:UseHearing .

<https://spectacular-voyage.github.io/test-inn-ambush/rules/dynamis/srd-5-2-1/conditions/condition/exhaustion>
  a dyn:ConditionDefinition, skos:Concept ;
  dcterms:isPartOf <https://spectacular-voyage.github.io/test-inn-ambush/rules/dynamis/srd-5-2-1/conditions> ;
  rdfs:label "Exhaustion" ;
  dyn:conditionKey "exhaustion" ;
  dyn:sourceSection "Rules Glossary: Exhaustion [Condition]" ;
  dyn:hasConditionEffect <https://spectacular-voyage.github.io/test-inn-ambush/rules/dynamis/srd-5-2-1/conditions/condition/exhaustion/effect/exhaustion-levels>,
    <https://spectacular-voyage.github.io/test-inn-ambush/rules/dynamis/srd-5-2-1/conditions/condition/exhaustion/effect/d20-tests-affected>,
    <https://spectacular-voyage.github.io/test-inn-ambush/rules/dynamis/srd-5-2-1/conditions/condition/exhaustion/effect/speed-reduced>,
    <https://spectacular-voyage.github.io/test-inn-ambush/rules/dynamis/srd-5-2-1/conditions/condition/exhaustion/effect/removing-exhaustion-levels> .

<https://spectacular-voyage.github.io/test-inn-ambush/rules/dynamis/srd-5-2-1/conditions/condition/exhaustion/effect/exhaustion-levels>
  a dyn:ConditionEffect ;
  dcterms:isPartOf <https://spectacular-voyage.github.io/test-inn-ambush/rules/dynamis/srd-5-2-1/conditions/condition/exhaustion> ;
  rdfs:label "Exhaustion Levels" ;
  rdf:value "This condition is cumulative. Each time you receive it, you gain 1 Exhaustion level. You die if your Exhaustion level is 6." ;
  dyn:effectKey "exhaustion-levels" ;
  dyn:effectKind "condition-counter" ;
  dyn:mechanicalStatus "structured-not-mask" ;
  dyn:sourceSection "Rules Glossary: Exhaustion [Condition]" ;
  dyn:adjudicationNote "Exhaustion levels are cumulative condition state, not an affordance mask." .

<https://spectacular-voyage.github.io/test-inn-ambush/rules/dynamis/srd-5-2-1/conditions/condition/exhaustion/effect/d20-tests-affected>
  a dyn:ConditionEffect ;
  dcterms:isPartOf <https://spectacular-voyage.github.io/test-inn-ambush/rules/dynamis/srd-5-2-1/conditions/condition/exhaustion> ;
  rdfs:label "D20 Tests Affected" ;
  rdf:value "When you make a D20 Test, the roll is reduced by 2 times your Exhaustion level." ;
  dyn:effectKey "d20-tests-affected" ;
  dyn:effectKind "d20-modifier" ;
  dyn:mechanicalStatus "structured-not-mask" ;
  dyn:sourceSection "Rules Glossary: Exhaustion [Condition]" ;
  dyn:adjudicationNote "The roll reduction is mechanical but is not an action mask." .

<https://spectacular-voyage.github.io/test-inn-ambush/rules/dynamis/srd-5-2-1/conditions/condition/exhaustion/effect/speed-reduced>
  a dyn:ConditionEffect ;
  dcterms:isPartOf <https://spectacular-voyage.github.io/test-inn-ambush/rules/dynamis/srd-5-2-1/conditions/condition/exhaustion> ;
  rdfs:label "Speed Reduced" ;
  rdf:value "Your Speed is reduced by a number of feet equal to 5 times your Exhaustion level." ;
  dyn:effectKey "speed-reduced" ;
  dyn:effectKind "movement-modifier" ;
  dyn:mechanicalStatus "structured-not-mask" ;
  dyn:sourceSection "Rules Glossary: Exhaustion [Condition]" ;
  dyn:adjudicationNote "Speed reduction may limit movement distance without masking Move entirely." .

<https://spectacular-voyage.github.io/test-inn-ambush/rules/dynamis/srd-5-2-1/conditions/condition/exhaustion/effect/removing-exhaustion-levels>
  a dyn:ConditionEffect ;
  dcterms:isPartOf <https://spectacular-voyage.github.io/test-inn-ambush/rules/dynamis/srd-5-2-1/conditions/condition/exhaustion> ;
  rdfs:label "Removing Exhaustion Levels" ;
  rdf:value "Finishing a Long Rest removes 1 of your Exhaustion levels. When your Exhaustion level reaches 0, the condition ends." ;
  dyn:effectKey "removing-exhaustion-levels" ;
  dyn:effectKind "condition-recovery" ;
  dyn:mechanicalStatus "structured-not-mask" ;
  dyn:sourceSection "Rules Glossary: Exhaustion [Condition]" ;
  dyn:adjudicationNote "Recovery timing is condition lifecycle data, not an action mask." .

<https://spectacular-voyage.github.io/test-inn-ambush/rules/dynamis/srd-5-2-1/conditions/condition/frightened>
  a dyn:ConditionDefinition, skos:Concept ;
  dcterms:isPartOf <https://spectacular-voyage.github.io/test-inn-ambush/rules/dynamis/srd-5-2-1/conditions> ;
  rdfs:label "Frightened" ;
  dyn:conditionKey "frightened" ;
  dyn:sourceSection "Rules Glossary: Frightened [Condition]" ;
  dyn:hasConditionEffect <https://spectacular-voyage.github.io/test-inn-ambush/rules/dynamis/srd-5-2-1/conditions/condition/frightened/effect/ability-checks-and-attacks-affected>,
    <https://spectacular-voyage.github.io/test-inn-ambush/rules/dynamis/srd-5-2-1/conditions/condition/frightened/effect/cant-approach> .

<https://spectacular-voyage.github.io/test-inn-ambush/rules/dynamis/srd-5-2-1/conditions/condition/frightened/effect/ability-checks-and-attacks-affected>
  a dyn:ConditionEffect ;
  dcterms:isPartOf <https://spectacular-voyage.github.io/test-inn-ambush/rules/dynamis/srd-5-2-1/conditions/condition/frightened> ;
  rdfs:label "Ability Checks and Attacks Affected" ;
  rdf:value "You have Disadvantage on ability checks and attack rolls while the source of fear is within line of sight." ;
  dyn:effectKey "ability-checks-and-attacks-affected" ;
  dyn:effectKind "d20-modifier" ;
  dyn:mechanicalStatus "structured-not-mask" ;
  dyn:sourceSection "Rules Glossary: Frightened [Condition]" ;
  dyn:adjudicationNote "The line-of-sight roll modifier is not an action mask." .

<https://spectacular-voyage.github.io/test-inn-ambush/rules/dynamis/srd-5-2-1/conditions/condition/frightened/effect/cant-approach>
  a dyn:ConditionEffect, dyn:AffordanceMaskDefinition ;
  dcterms:isPartOf <https://spectacular-voyage.github.io/test-inn-ambush/rules/dynamis/srd-5-2-1/conditions/condition/frightened> ;
  rdfs:label "Can't Approach" ;
  rdf:value "You can't willingly move closer to the source of fear." ;
  dyn:effectKey "cant-approach" ;
  dyn:effectKind "conditional-affordance-mask" ;
  dyn:mechanicalStatus "adjudication-scoped-mask" ;
  dyn:sourceSection "Rules Glossary: Frightened [Condition]" ;
  dyn:adjudicationNote "The mask applies only to willing movement closer to the fear source." ;
  dyn:masksActionType dyn:MoveCloserToConditionSource .

<https://spectacular-voyage.github.io/test-inn-ambush/rules/dynamis/srd-5-2-1/conditions/condition/grappled>
  a dyn:ConditionDefinition, skos:Concept ;
  dcterms:isPartOf <https://spectacular-voyage.github.io/test-inn-ambush/rules/dynamis/srd-5-2-1/conditions> ;
  rdfs:label "Grappled" ;
  dyn:conditionKey "grappled" ;
  dyn:sourceSection "Rules Glossary: Grappled [Condition]" ;
  dyn:hasConditionEffect <https://spectacular-voyage.github.io/test-inn-ambush/rules/dynamis/srd-5-2-1/conditions/condition/grappled/effect/speed-0>,
    <https://spectacular-voyage.github.io/test-inn-ambush/rules/dynamis/srd-5-2-1/conditions/condition/grappled/effect/attacks-affected>,
    <https://spectacular-voyage.github.io/test-inn-ambush/rules/dynamis/srd-5-2-1/conditions/condition/grappled/effect/movable> .

<https://spectacular-voyage.github.io/test-inn-ambush/rules/dynamis/srd-5-2-1/conditions/condition/grappled/effect/speed-0>
  a dyn:ConditionEffect, dyn:AffordanceMaskDefinition ;
  dcterms:isPartOf <https://spectacular-voyage.github.io/test-inn-ambush/rules/dynamis/srd-5-2-1/conditions/condition/grappled> ;
  rdfs:label "Speed 0" ;
  rdf:value "Your Speed is 0 and can't increase." ;
  dyn:effectKey "speed-0" ;
  dyn:effectKind "affordance-mask" ;
  dyn:mechanicalStatus "codified-mask" ;
  dyn:sourceSection "Rules Glossary: Grappled [Condition]" ;
  dyn:masksActionType dyn:Move .

<https://spectacular-voyage.github.io/test-inn-ambush/rules/dynamis/srd-5-2-1/conditions/condition/grappled/effect/attacks-affected>
  a dyn:ConditionEffect ;
  dcterms:isPartOf <https://spectacular-voyage.github.io/test-inn-ambush/rules/dynamis/srd-5-2-1/conditions/condition/grappled> ;
  rdfs:label "Attacks Affected" ;
  rdf:value "You have Disadvantage on attack rolls against any target other than the grappler." ;
  dyn:effectKey "attacks-affected" ;
  dyn:effectKind "d20-modifier" ;
  dyn:mechanicalStatus "structured-not-mask" ;
  dyn:sourceSection "Rules Glossary: Grappled [Condition]" ;
  dyn:adjudicationNote "The attack-roll disadvantage is a roll modifier, not an action mask." .

<https://spectacular-voyage.github.io/test-inn-ambush/rules/dynamis/srd-5-2-1/conditions/condition/grappled/effect/movable>
  a dyn:ConditionEffect ;
  dcterms:isPartOf <https://spectacular-voyage.github.io/test-inn-ambush/rules/dynamis/srd-5-2-1/conditions/condition/grappled> ;
  rdfs:label "Movable" ;
  rdf:value "The grappler can drag or carry you when it moves, but every foot of movement costs it 1 extra foot unless you are Tiny or two or more sizes smaller than it." ;
  dyn:effectKey "movable" ;
  dyn:effectKind "movement-adjudication" ;
  dyn:mechanicalStatus "adjudication-required" ;
  dyn:sourceSection "Rules Glossary: Grappled [Condition]" ;
  dyn:adjudicationNote "Dragging or carrying the grappled target depends on grappler movement and relative size." .

<https://spectacular-voyage.github.io/test-inn-ambush/rules/dynamis/srd-5-2-1/conditions/condition/incapacitated>
  a dyn:ConditionDefinition, skos:Concept ;
  dcterms:isPartOf <https://spectacular-voyage.github.io/test-inn-ambush/rules/dynamis/srd-5-2-1/conditions> ;
  rdfs:label "Incapacitated" ;
  dyn:conditionKey "incapacitated" ;
  dyn:sourceSection "Rules Glossary: Incapacitated [Condition]" ;
  dyn:hasConditionEffect <https://spectacular-voyage.github.io/test-inn-ambush/rules/dynamis/srd-5-2-1/conditions/condition/incapacitated/effect/inactive>,
    <https://spectacular-voyage.github.io/test-inn-ambush/rules/dynamis/srd-5-2-1/conditions/condition/incapacitated/effect/no-concentration>,
    <https://spectacular-voyage.github.io/test-inn-ambush/rules/dynamis/srd-5-2-1/conditions/condition/incapacitated/effect/speechless>,
    <https://spectacular-voyage.github.io/test-inn-ambush/rules/dynamis/srd-5-2-1/conditions/condition/incapacitated/effect/surprised> .

<https://spectacular-voyage.github.io/test-inn-ambush/rules/dynamis/srd-5-2-1/conditions/condition/incapacitated/effect/inactive>
  a dyn:ConditionEffect, dyn:AffordanceMaskDefinition ;
  dcterms:isPartOf <https://spectacular-voyage.github.io/test-inn-ambush/rules/dynamis/srd-5-2-1/conditions/condition/incapacitated> ;
  rdfs:label "Inactive" ;
  rdf:value "You can't take any action, Bonus Action, or Reaction." ;
  dyn:effectKey "inactive" ;
  dyn:effectKind "affordance-mask" ;
  dyn:mechanicalStatus "codified-mask" ;
  dyn:sourceSection "Rules Glossary: Incapacitated [Condition]" ;
  dyn:masksActionType dyn:TakeAction, dyn:TakeBonusAction, dyn:TakeReaction .

