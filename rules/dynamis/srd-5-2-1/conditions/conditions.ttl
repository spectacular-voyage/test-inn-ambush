<https://spectacular-voyage.github.io/test-inn-ambush/rules/dynamis/srd-5-2-1/conditions>
  a dcat:Dataset ;
  dcterms:title "SRD 5.2.1 condition rules" ;
  dcterms:description "Curated condition definitions extracted from the CC SRD 5.2.1 PDF. Mask rows name action-family affordances; non-mask mechanical effects remain explicit data." ;
  dcterms:created "2026-07-05"^^xsd:date ;
  dcterms:license <https://creativecommons.org/licenses/by/4.0/> ;
  dcterms:source <https://media.dndbeyond.com/compendium-images/srd/5.2/SRD_CC_v5.2.1.pdf> ;
  dcterms:rights "Includes material from System Reference Document 5.2.1 by Wizards of the Coast LLC, available under the Creative Commons Attribution 4.0 International License." ;
  dcat:distribution <https://spectacular-voyage.github.io/test-inn-ambush/rules/dynamis/srd-5-2-1/conditions/conditions-effects-csv>,
    <https://spectacular-voyage.github.io/test-inn-ambush/rules/dynamis/srd-5-2-1/conditions/conditions-csvw> .

<https://spectacular-voyage.github.io/test-inn-ambush/rules/dynamis/srd-5-2-1/conditions/conditions-effects-csv>
  a dcat:Distribution ;
  dcterms:title "SRD 5.2.1 condition effects curated CSV" ;
  dcat:downloadURL <https://spectacular-voyage.github.io/test-inn-ambush/rules/dynamis/srd-5-2-1/conditions/conditions.effects.csv> .

<https://spectacular-voyage.github.io/test-inn-ambush/rules/dynamis/srd-5-2-1/conditions/conditions-csvw>
  a dcat:Distribution ;
  dcterms:title "SRD 5.2.1 condition CSVW mapping" ;
  dcat:downloadURL <https://spectacular-voyage.github.io/test-inn-ambush/rules/dynamis/srd-5-2-1/conditions/conditions.csvw.json> .

dyn:ConditionMaskAdjudicatedPreconditionAsk
  a dyn:SparqlAskPrecondition ;
  rdf:value "ASK { # Condition mask family is adjudicated by the condition effect and live mask interval. }" .

dyn:ConditionMaskAdjudicatedConsequenceTemplate
  a dyn:ConsequenceTemplate ;
  rdf:value "No standalone consequence template; this action family exists so source-derived condition masks can name the affordance they suspend." .

dyn:HarmConditionSource
  a dyn:ActionType, owl:Class ;
  rdfs:label "Harm condition source" ;
  dyn:verbIri dyn:harm-condition-source ;
  dyn:preconditionAsk dyn:ConditionMaskAdjudicatedPreconditionAsk ;
  dyn:consequenceTemplate dyn:ConditionMaskAdjudicatedConsequenceTemplate ;
  dyn:punningDecision "ActionType is an individual rules record and an OWL class for source-derived condition-mask family references." ;
  dyn:srdReference "SRD 5.2.1 condition rules" .

