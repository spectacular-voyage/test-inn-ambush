<https://spectacular-voyage.github.io/test-inn-ambush/rules/dynamis/srd-5-2-1/conditions/condition/invisible/effect/concealed>
  a dyn:ConditionEffect ;
  dcterms:isPartOf <https://spectacular-voyage.github.io/test-inn-ambush/rules/dynamis/srd-5-2-1/conditions/condition/invisible> ;
  rdfs:label "Concealed" ;
  rdf:value "You aren't affected by any effect that requires its target to be seen unless the effect's creator can somehow see you. Any equipment you are wearing or carrying is also concealed." ;
  dyn:effectKey "concealed" ;
  dyn:effectKind "targeting-adjudication" ;
  dyn:mechanicalStatus "adjudication-required" ;
  dyn:sourceSection "Rules Glossary: Invisible [Condition]" ;
  dyn:adjudicationNote "Sight-required targeting is source/observer dependent; this package records the prose rather than inventing a targeting engine." .

<https://spectacular-voyage.github.io/test-inn-ambush/rules/dynamis/srd-5-2-1/conditions/condition/invisible/effect/attacks-affected>
  a dyn:ConditionEffect ;
  dcterms:isPartOf <https://spectacular-voyage.github.io/test-inn-ambush/rules/dynamis/srd-5-2-1/conditions/condition/invisible> ;
  rdfs:label "Attacks Affected" ;
  rdf:value "Attack rolls against you have Disadvantage, and your attack rolls have Advantage. If a creature can somehow see you, you don't gain this benefit against that creature." ;
  dyn:effectKey "attacks-affected" ;
  dyn:effectKind "d20-modifier" ;
  dyn:mechanicalStatus "structured-not-mask" ;
  dyn:sourceSection "Rules Glossary: Invisible [Condition]" ;
  dyn:adjudicationNote "Attack-roll advantage and disadvantage are roll modifiers, not action masks." .

