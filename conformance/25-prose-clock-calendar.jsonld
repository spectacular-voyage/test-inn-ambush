              "id": "#ask-custom-calendar-package",
              "type": "SparqlAskAssertion",
              "query": "ASK { <https://spectacular-voyage.github.io/test-inn-ambush/world/calendars/inn-ambush-calendar> a <https://spectacular-voyage.github.io/stagecraft/ontology/temporaenum/Calendar> ; <https://spectacular-voyage.github.io/stagecraft/ontology/temporaenum/calendarKind> \"custom\" ; <https://spectacular-voyage.github.io/stagecraft/ontology/temporaenum/secondsPerDay> \"86400.0\"^^<http://www.w3.org/2001/XMLSchema#decimal> ; <https://spectacular-voyage.github.io/stagecraft/ontology/temporaenum/epochSecondOfDay> \"74580.0\"^^<http://www.w3.org/2001/XMLSchema#decimal> ; <https://spectacular-voyage.github.io/stagecraft/ontology/temporaenum/hasWeekday> <https://spectacular-voyage.github.io/test-inn-ambush/world/calendars/inn-ambush-calendar/weekday/toilday> ; <https://spectacular-voyage.github.io/stagecraft/ontology/temporaenum/hasSeason> <https://spectacular-voyage.github.io/test-inn-ambush/world/calendars/inn-ambush-calendar/season/early-autumn> ; <https://spectacular-voyage.github.io/stagecraft/ontology/temporaenum/hasTimeOfDayBand> <https://spectacular-voyage.github.io/test-inn-ambush/world/calendars/inn-ambush-calendar/band/late-evening>, <https://spectacular-voyage.github.io/test-inn-ambush/world/calendars/inn-ambush-calendar/band/night-after-evening> . <https://spectacular-voyage.github.io/test-inn-ambush/world/calendars/inn-ambush-calendar/weekday/toilday> <http://www.w3.org/2000/01/rdf-schema#label> \"Toilday\" ; <https://spectacular-voyage.github.io/stagecraft/ontology/temporaenum/ordinal> 1 . <https://spectacular-voyage.github.io/test-inn-ambush/world/calendars/inn-ambush-calendar/band/late-evening> <http://www.w3.org/2000/01/rdf-schema#label> \"late evening\" ; <https://spectacular-voyage.github.io/stagecraft/ontology/temporaenum/fromHour> \"18.0\"^^<http://www.w3.org/2001/XMLSchema#decimal> ; <https://spectacular-voyage.github.io/stagecraft/ontology/temporaenum/toHour> \"21.0\"^^<http://www.w3.org/2001/XMLSchema#decimal> . }",
              "expectedBoolean": true
