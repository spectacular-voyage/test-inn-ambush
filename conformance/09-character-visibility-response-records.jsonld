              "query": "ASK { <https://spectacular-voyage.github.io/test-inn-ambush/actant/elara> a <https://spectacular-voyage.github.io/stagecraft/ontology/Character> ; <https://spectacular-voyage.github.io/stagecraft/ontology/visibleTo> <https://spectacular-voyage.github.io/test-inn-ambush/participant/alice> ; <https://spectacular-voyage.github.io/stagecraft/ontology/visibleTo> <https://spectacular-voyage.github.io/test-inn-ambush/gm/alex> . <https://spectacular-voyage.github.io/test-inn-ambush/actant/nera> a <https://spectacular-voyage.github.io/stagecraft/ontology/Character> ; <https://spectacular-voyage.github.io/stagecraft/ontology/visibleTo> <https://spectacular-voyage.github.io/test-inn-ambush/participant/alice> ; <https://spectacular-voyage.github.io/stagecraft/ontology/visibleTo> <https://spectacular-voyage.github.io/test-inn-ambush/gm/alex> . }",
