        "locatorKind": "gitRefState",
        "ref": "a.04-plan-b-recommendation-woven"
      },
      "toState": {
        "type": "StateLocator",
        "locatorKind": "gitRefState",
        "ref": "a.05-participant-projection-contract-rename-records"
      },
      "hasFileExpectation": [
        {
          "id": "#readme",
          "type": "FileExpectation",
