          "compareMode": "rdfCanonical"
        },
        {
          "id": "#journal-history-index",
          "type": "FileExpectation",
          "path": "authority/journals/plan-b/_history001/index.html",
          "changeType": "updated",
          "compareMode": "text"
        },
        {
          "id": "#journal-knop-inventory-page",
