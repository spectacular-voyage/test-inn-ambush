  "hasCase": [
    {
      "type": "TransitionCase",
      "id": "#weave-d20-roll-evidence",
      "fixtureRepo": "github.com/spectacular-voyage/test-inn-ambush",
      "operationId": "stagecraft.fixture.weaveD20RollEvidence",
      "fromRef": "a.27-d20-roll-evidence-records",
      "toRef": "a.28-d20-roll-evidence-woven",
      "fromState": {
        "type": "StateLocator",
        "locatorKind": "gitRefState",
