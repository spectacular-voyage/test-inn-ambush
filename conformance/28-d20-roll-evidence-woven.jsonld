      "hasRdfExpectation": [
        {
          "id": "#journal-knop-inventory-rdf",
          "type": "RdfExpectation",
          "targetsFileExpectation": "#journal-knop-inventory",
          "hasAskAssertion": [
            {
              "id": "#ask-s0004-latest-state",
              "type": "SparqlAskAssertion",
              "query": "ASK { <https://spectacular-voyage.github.io/test-inn-ambush/authority/journals/plan-b/_history001> <https://semantic-flow.github.io/sflo/ontology/latestHistoricalState> <https://spectacular-voyage.github.io/test-inn-ambush/authority/journals/plan-b/_history001/_s0004> ; <https://semantic-flow.github.io/sflo/ontology/nextStateOrdinal> \"5\"^^<http://www.w3.org/2001/XMLSchema#nonNegativeInteger> . <https://spectacular-voyage.github.io/test-inn-ambush/authority/journals/plan-b/_history001/_s0004> a <https://semantic-flow.github.io/sflo/ontology/HistoricalState> ; <https://semantic-flow.github.io/sflo/ontology/previousHistoricalState> <https://spectacular-voyage.github.io/test-inn-ambush/authority/journals/plan-b/_history001/_s0003> ; <https://semantic-flow.github.io/sflo/ontology/locatedFileForState> <https://spectacular-voyage.github.io/test-inn-ambush/authority/journals/plan-b/_history001/_s0004/ttl/plan-b.ttl> ; <https://semantic-flow.github.io/sflo/ontology/hasResourcePage> <https://spectacular-voyage.github.io/test-inn-ambush/authority/journals/plan-b/_history001/_s0004/index.html> . }",
              "expectedBoolean": true
            }
          ]
        },
        {
          "id": "#journal-history-payload-rdf",
          "type": "RdfExpectation",
          "targetsFileExpectation": "#journal-history-payload",
          "hasAskAssertion": [
            {
              "id": "#ask-woven-payload-carries-roll-evidence",
              "type": "SparqlAskAssertion",
              "query": "ASK { <https://spectacular-voyage.github.io/test-inn-ambush/authority-journal/d20-roll/perception-check-001> a <https://spectacular-voyage.github.io/stagecraft/ontology/dynamis/D20RollEvidence> ; <https://spectacular-voyage.github.io/stagecraft/ontology/dynamis/diceExpression> \"1d20+3+2\" ; <https://spectacular-voyage.github.io/stagecraft/ontology/dynamis/rawDieFace> 8 ; <https://spectacular-voyage.github.io/stagecraft/ontology/dynamis/rollTotal> 13 . <https://spectacular-voyage.github.io/test-inn-ambush/authority-journal/d20-test-outcome/perception-check-001> <https://spectacular-voyage.github.io/stagecraft/ontology/dynamis/rollEvidence> <https://spectacular-voyage.github.io/test-inn-ambush/authority-journal/d20-roll/perception-check-001> ; <https://spectacular-voyage.github.io/stagecraft/ontology/dynamis/mechanicalResult> \"failure\" ; <https://spectacular-voyage.github.io/stagecraft/ontology/dynamis/adjudicatedResult> \"success\" . }",
              "expectedBoolean": true
            }
          ]
        }
      ]
    }
  ]
