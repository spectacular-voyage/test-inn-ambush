        "ref": "a.28-d20-roll-evidence-woven"
      },
      "hasFileExpectation": [
        {
          "id": "#journal-history-state-page",
          "type": "FileExpectation",
          "path": "authority/journals/plan-b/_history001/_s0004/index.html",
          "changeType": "added",
          "compareMode": "text"
        },
        {
          "id": "#journal-history-state-manifestation-page",
          "type": "FileExpectation",
          "path": "authority/journals/plan-b/_history001/_s0004/ttl/index.html",
          "changeType": "added",
