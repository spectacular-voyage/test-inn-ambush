          "hasAskAssertion": [
            {
              "id": "#ask-spell-area-shapes",
              "type": "SparqlAskAssertion",
              "query": "ASK { <https://spectacular-voyage.github.io/test-inn-ambush/rules/dynamis/srd-5-2-1/spells> <http://www.w3.org/ns/dcat#distribution> <https://spectacular-voyage.github.io/test-inn-ambush/rules/dynamis/srd-5-2-1/spells/spell-area-shapes-csv> . <https://spectacular-voyage.github.io/test-inn-ambush/rules/dynamis/srd-5-2-1/spells/spell/fireball> <https://spectacular-voyage.github.io/stagecraft/ontology/dynamis/areaShape> <https://spectacular-voyage.github.io/test-inn-ambush/rules/dynamis/srd-5-2-1/spells/area-shape/fireball-sphere-20> . <https://spectacular-voyage.github.io/test-inn-ambush/rules/dynamis/srd-5-2-1/spells/area-shape/fireball-sphere-20> a <https://spectacular-voyage.github.io/stagecraft/ontology/dynamis/AreaOfEffectShape> ; <http://www.w3.org/2000/01/rdf-schema#label> \"Fireball sphere area\" ; <https://spectacular-voyage.github.io/stagecraft/ontology/dynamis/areaShapeKind> \"sphere\" ; <https://spectacular-voyage.github.io/stagecraft/ontology/dynamis/radiusFeet> 20 ; <https://spectacular-voyage.github.io/stagecraft/ontology/dynamis/sourceSection> \"Spell Descriptions: Fireball\" . <https://spectacular-voyage.github.io/test-inn-ambush/rules/dynamis/srd-5-2-1/spells/spell/shatter> <https://spectacular-voyage.github.io/stagecraft/ontology/dynamis/areaShape> <https://spectacular-voyage.github.io/test-inn-ambush/rules/dynamis/srd-5-2-1/spells/area-shape/shatter-sphere-10> . <https://spectacular-voyage.github.io/test-inn-ambush/rules/dynamis/srd-5-2-1/spells/area-shape/shatter-sphere-10> a <https://spectacular-voyage.github.io/stagecraft/ontology/dynamis/AreaOfEffectShape> ; <https://spectacular-voyage.github.io/stagecraft/ontology/dynamis/areaShapeKind> \"sphere\" ; <https://spectacular-voyage.github.io/stagecraft/ontology/dynamis/radiusFeet> 10 . }",
              "expectedBoolean": true
