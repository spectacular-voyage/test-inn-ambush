        },
        {
          "id": "#world-state-rdf-expectation",
          "type": "RdfExpectation",
          "targetsFileExpectation": "#world-state",
          "hasAskAssertion": [
            {
              "id": "#ask-measured-zone-spatial-state",
              "type": "SparqlAskAssertion",
              "query": "ASK { <https://spectacular-voyage.github.io/test-inn-ambush/scenario/inn-ambush> <https://spectacular-voyage.github.io/stagecraft/ontology/hasSpatialModel> <https://spectacular-voyage.github.io/stagecraft/ontology/spatial-model/r0-zone-graph> . <https://spectacular-voyage.github.io/test-inn-ambush/frame/ambush-night> <https://spectacular-voyage.github.io/stagecraft/ontology/hasSpatialModel> <https://spectacular-voyage.github.io/stagecraft/ontology/spatial-model/r1-measured-zones> . <https://spectacular-voyage.github.io/test-inn-ambush/place/common-room> <https://spectacular-voyage.github.io/stagecraft/ontology/zoneExtentFeet> \"60.0\"^^<http://www.w3.org/2001/XMLSchema#decimal> ; <https://spectacular-voyage.github.io/stagecraft/ontology/elevationBand> 0 ; <https://spectacular-voyage.github.io/stagecraft/ontology/hasLocus> <https://spectacular-voyage.github.io/test-inn-ambush/locus/common-room/by-the-bar>, <https://spectacular-voyage.github.io/test-inn-ambush/locus/common-room/near-front-door>, <https://spectacular-voyage.github.io/test-inn-ambush/locus/common-room/loft-landing> . <https://spectacular-voyage.github.io/test-inn-ambush/locus/common-room/loft-landing> a <https://spectacular-voyage.github.io/stagecraft/ontology/NamedLocus> ; <https://spectacular-voyage.github.io/stagecraft/ontology/locatedIn> <https://spectacular-voyage.github.io/test-inn-ambush/place/common-room> ; <https://spectacular-voyage.github.io/stagecraft/ontology/elevationBand> 2 . <https://spectacular-voyage.github.io/test-inn-ambush/spatial/locus-distance/common-room/bar-to-door> <https://spectacular-voyage.github.io/stagecraft/ontology/fromLocus> <https://spectacular-voyage.github.io/test-inn-ambush/locus/common-room/by-the-bar> ; <https://spectacular-voyage.github.io/stagecraft/ontology/toLocus> <https://spectacular-voyage.github.io/test-inn-ambush/locus/common-room/near-front-door> ; <https://spectacular-voyage.github.io/stagecraft/ontology/distanceFeet> \"25.0\"^^<http://www.w3.org/2001/XMLSchema#decimal> . <https://spectacular-voyage.github.io/test-inn-ambush/spatial/edge/common-room-front-door-threshold> a <https://spectacular-voyage.github.io/stagecraft/ontology/ZoneEdge> ; <https://spectacular-voyage.github.io/stagecraft/ontology/fromPlace> <https://spectacular-voyage.github.io/test-inn-ambush/place/common-room> ; <https://spectacular-voyage.github.io/stagecraft/ontology/toPlace> <https://spectacular-voyage.github.io/test-inn-ambush/place/front-door-threshold> ; <https://spectacular-voyage.github.io/stagecraft/ontology/distanceFeet> \"10.0\"^^<http://www.w3.org/2001/XMLSchema#decimal> ; <https://spectacular-voyage.github.io/stagecraft/ontology/lineOfEffectState> \"partial\" . <https://spectacular-voyage.github.io/test-inn-ambush/spatial/edge/front-door-threshold-old-road> a <https://spectacular-voyage.github.io/stagecraft/ontology/ZoneEdge> ; <https://spectacular-voyage.github.io/stagecraft/ontology/fromPlace> <https://spectacular-voyage.github.io/test-inn-ambush/place/front-door-threshold> ; <https://spectacular-voyage.github.io/stagecraft/ontology/toPlace> <https://spectacular-voyage.github.io/test-inn-ambush/place/old-road> ; <https://spectacular-voyage.github.io/stagecraft/ontology/distanceFeet> \"120.0\"^^<http://www.w3.org/2001/XMLSchema#decimal> ; <https://spectacular-voyage.github.io/stagecraft/ontology/lineOfEffectState> \"blocked\" . <https://spectacular-voyage.github.io/test-inn-ambush/relator/location/elara/common-room-current> <https://spectacular-voyage.github.io/stagecraft/ontology/locus> <https://spectacular-voyage.github.io/test-inn-ambush/locus/common-room/by-the-bar> ; <https://spectacular-voyage.github.io/stagecraft/ontology/elevationBand> 0 . <https://spectacular-voyage.github.io/test-inn-ambush/relator/location/front-door/front-door-threshold-current> <https://spectacular-voyage.github.io/stagecraft/ontology/locus> <https://spectacular-voyage.github.io/test-inn-ambush/locus/front-door-threshold/at-do