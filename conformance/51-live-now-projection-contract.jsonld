          "targetsFileExpectation": "#contract-shapes",
          "hasAskAssertion": [
            {
              "id": "#ask-timeline-state-kind",
              "type": "SparqlAskAssertion",
              "query": "ASK { <https://spectacular-voyage.github.io/stagecraft/shacl/ProjectionTimelineStateShape> <http://www.w3.org/ns/shacl#property> ?kindProperty, ?checkpointProperty . ?kindProperty <http://www.w3.org/ns/shacl#path> <https://spectacular-voyage.github.io/stagecraft/ontology/timelineStateKind> ; <http://www.w3.org/ns/shacl#minCount> \"1\"^^<http://www.w3.org/2001/XMLSchema#integer> ; <http://www.w3.org/ns/shacl#maxCount> \"1\"^^<http://www.w3.org/2001/XMLSchema#integer> ; <http://www.w3.org/ns/shacl#in> ?allowedKinds . ?checkpointProperty <http://www.w3.org/ns/shacl#path> <https://spectacular-voyage.github.io/stagecraft/ontology/checkpoint> ; <http://www.w3.org/ns/shacl#maxCount> \"1\"^^<http://www.w3.org/2001/XMLSchema#integer> . FILTER NOT EXISTS { ?checkpointProperty <http://www.w3.org/ns/shacl#minCount> ?checkpointMin . } }",
              "expectedBoolean": true
            },
            {
              "id": "#ask-checkpoint-request-shape",
              "type": "SparqlAskAssertion",
              "query": "ASK { <https://spectacular-voyage.github.io/stagecraft/shacl/CheckpointRequestShape> a <http://www.w3.org/ns/shacl#NodeShape> ; <http://www.w3.org/ns/shacl#targetClass> <https://spectacular-voyage.github.io/stagecraft/ontology/CheckpointRequest> ; <http://www.w3.org/ns/shacl#property> ?typeProperty, ?labelProperty, ?projectionProperty . ?typeProperty <http://www.w3.org/ns/shacl#path> <https://spectacular-voyage.github.io/stagecraft/ontology/envelopeType> ; <http://www.w3.org/ns/shacl#hasValue> \"stagecraft.checkpoint.request.v1\" . ?labelProperty <http://www.w3.org/ns/shacl#path> <https://spectacular-voyage.github.io/stagecraft/ontology/label> ; <http://www.w3.org/ns/shacl#minCount> \"1\"^^<http://www.w3.org/2001/XMLSchema#integer> . ?projectionProperty <http://www.w3.org/ns/shacl#path> <https://spectacular-voyage.github.io/stagecraft/ontology/sourceProjection> ; <http://www.w3.org/ns/shacl#node> <https://spectacular-voyage.github.io/stagecraft/shacl/SourceProjectionShape> . }",
              "expectedBoolean": true
