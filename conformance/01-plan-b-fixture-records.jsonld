{
  "@context": {
    "@vocab": "https://spectacular-voyage.github.io/accord/ontology/",
    "dcterms": "http://purl.org/dc/terms/",
    "id": "@id",
    "type": "@type",
    "changeType": {
      "@type": "@vocab"
    },
    "compareMode": {
      "@type": "@vocab"
    },
    "targetsFileExpectation": {
      "@type": "@id"
    },
    "locatorKind": {
      "@type": "@vocab"
    }
  },
  "type": "Manifest",
  "id": "urn:accord:stagecraft:test-inn-ambush:01-plan-b-fixture-records",
  "dcterms:title": "Inn Ambush 01 Plan B fixture records",
  "hasCase": [
    {
      "type": "TransitionCase",
      "id": "#seed-plan-b-records",
      "fixtureRepo": "github.com/spectacular-voyage/test-inn-ambush",
      "operationId": "stagecraft.fixture.seedPlanBRecords",
      "fromRef": "a.00-empty-mesh",
      "toRef": "a.01-plan-b-fixture-records",
      "fromState": {
        "type": "StateLocator",
        "locatorKind": "gitRefState",
        "ref": "a.00-empty-mesh"
      },
      "toState": {
        "type": "StateLocator",
        "locatorKind": "gitRefState",
        "ref": "a.01-plan-b-fixture-records"
      },
      "hasFileExpectation": [
        {
          "id": "#readme",
          "type": "FileExpectation",
          "path": "README.md",
          "changeType": "updated",
          "compareMode": "text"
        },
        {
          "id": "#authority-journal-plan-b",
          "type": "FileExpectation",
          "path": "authority/journals/plan-b/plan-b.ttl",
          "changeType": "added",
          "compareMode": "rdfCanonical"
        },
        {
          "id": "#authority-operation-request",
          "type": "FileExpectation",
          "path": "authority/operations/authority-operation-request-plan-b-commit/authority-operation-request-plan-b-commit.json",
          "changeType": "added"
        },
        {
          "id": "#projection-context",
          "type": "FileExpectation",
          "path": "projections/contracts/inn-ambush-contract.context.jsonld",
          "changeType": "added"
        },
        {
          "id": "#projection-shapes",
          "type": "FileExpectation",
          "path": "projections/contracts/inn-ambush-contract.shapes.ttl",
          "changeType": "added",
          "compareMode": "rdfCanonical"
        },
        {
          "id": "#projection-ready",
          "type": "FileExpectation",
          "path": "projections/notifications/plan-b-projection-ready/plan-b-projection-ready.json",
          "changeType": "added"
        },
        {
          "id": "#projection-request-alice",
          "type": "FileExpectation",
          "path": "projections/requests/participant-projection-request-alice/participant-projection-request-alice.json",
          "changeType": "added"
        },
        {
          "id": "#chat-contribution",
          "type": "FileExpectation",
          "path": "sessions/contributions/chat-contribution-plan-b-suggestion/chat-contribution-plan-b-suggestion.json",
          "changeType": "added"
        },
        {
          "id": "#world-state-plan-b",
          "type": "FileExpectation",
          "path": "world/states/inn-ambush-plan-b-state/inn-ambush-plan-b-state.ttl",
          "changeType": "added",
          "compareMode": "rdfCanonical"
        }
      ],
      "hasRdfExpectation": [
        {
          "id": "#authority-journal-rdf",
          "type": "RdfExpectation",
          "targetsFileExpectation": "#authority-journal-plan-b",
          "hasAskAssertion": [
            {
              "id": "#ask-outcome-committed",
              "type": "SparqlAskAssertion",
              "query": "ASK { <https://spectacular-voyage.github.io/test-inn-ambush/authority-journal/outcome-committed/plan-b-001> a <https://stagecraft.dev/ns/stagecraft/OutcomeCommitted> ; <https://stagecraft.dev/ns/stagecraft/committedEvent> <https://spectacular-voyage.github.io/test-inn-ambush/committed-event/plan-b-001> ; <https://stagecraft.dev/ns/stagecraft/hasCommitCertificate> <https://spectacular-voyage.github.io/test-inn-ambush/authority-journal/commit-certificate/plan-b-001> . }",
              "expectedBoolean": true
            },
            {
              "id": "#ask-commit-certificate",
              "type": "SparqlAskAssertion",
              "query": "ASK { <https://spectacular-voyage.github.io/test-inn-ambush/authority-journal/commit-certificate/plan-b-001> a <https://stagecraft.dev/ns/stagecraft/CommitCertificate> ; <https://stagecraft.dev/ns/stagecraft/committedEvent> <https://spectacular-voyage.github.io/test-inn-ambush/committed-event/plan-b-001> . }",
              "expectedBoolean": true
            },
            {
              "id": "#ask-committed-event",
              "type": "SparqlAskAssertion",
              "query": "ASK { <https://spectacular-voyage.github.io/test-inn-ambush/committed-event/plan-b-001> a <https://stagecraft.dev/ns/stagecraft/CommittedEvent> ; <https://stagecraft.dev/ns/stagecraft/producesStateMutation> <https://spectacular-voyage.github.io/test-inn-ambush/state-mutation/door-barred-plan-b-001> . }",
              "expectedBoolean": true
            }
          ]
        },
        {
          "id": "#projection-shapes-rdf",
          "type": "RdfExpectation",
          "targetsFileExpectation": "#projection-shapes",
          "hasAskAssertion": [
            {
              "id": "#ask-projection-notification-shape",
              "type": "SparqlAskAssertion",
              "query": "ASK { <https://stagecraft.dev/ns/provisional/stagecraft-contract-shape#ProjectionNotificationShape> a <http://www.w3.org/ns/shacl#NodeShape> ; <http://www.w3.org/ns/shacl#targetClass> <https://stagecraft.dev/ns/stagecraft/ProjectionNotification> . }",
              "expectedBoolean": true
            },
            {
              "id": "#ask-authority-operation-shape",
              "type": "SparqlAskAssertion",
              "query": "ASK { <https://stagecraft.dev/ns/provisional/stagecraft-contract-shape#AuthorityOperationShape> a <http://www.w3.org/ns/shacl#NodeShape> ; <http://www.w3.org/ns/shacl#targetClass> <https://stagecraft.dev/ns/stagecraft/AuthorityOperation> . }",
              "expectedBoolean": true
            }
          ]
        },
        {
          "id": "#world-state-rdf",
          "type": "RdfExpectation",
          "targetsFileExpectation": "#world-state-plan-b",
          "hasAskAssertion": [
            {
              "id": "#ask-historical-state",
              "type": "SparqlAskAssertion",
              "query": "ASK { <https://spectacular-voyage.github.io/test-inn-ambush/rdf-export/inn-ambush-plan-b/state/s0001> a <https://semantic-flow.github.io/sflo/ontology/HistoricalState> ; <https://semantic-flow.github.io/sflo/ontology/locatedFileForState> <https://spectacular-voyage.github.io/test-inn-ambush/rdf-export/inn-ambush-plan-b/file/ttl> . }",
              "expectedBoolean": true
            },
            {
              "id": "#ask-door-barred",
              "type": "SparqlAskAssertion",
              "query": "ASK { <https://spectacular-voyage.github.io/test-inn-ambush/target/door> a <https://stagecraft.dev/ns/stagecraft/Target> ; <https://stagecraft.dev/ns/stagecraft/barred> \"true\"^^<http://www.w3.org/2001/XMLSchema#boolean> ; <https://stagecraft.dev/ns/stagecraft/lastCommittedEvent> <https://spectacular-voyage.github.io/test-inn-ambush/committed-event/plan-b-001> . }",
              "expectedBoolean": true
            },
            {
              "id": "#ask-state-mutation",
              "type": "SparqlAskAssertion",
              "query": "ASK { <https://spectacular-voyage.github.io/test-inn-ambush/state-mutation/door-barred-plan-b-001> a <https://stagecraft.dev/ns/stagecraft/StateMutation> ; <https://stagecraft.dev/ns/stagecraft/causedByCommittedEvent> <https://spectacular-voyage.github.io/test-inn-ambush/committed-event/plan-b-001> ; <https://stagecraft.dev/ns/stagecraft/affectsEntity> <https://spectacular-voyage.github.io/test-inn-ambush/target/door> . }",
              "expectedBoolean": true
            }
          ]
        }
      ]
    }
  ]
}
