              "type": "SparqlAskAssertion",
              "query": "ASK { <https://spectacular-voyage.github.io/test-inn-ambush/relator/door-barred/plan-b-001-current> a <https://spectacular-voyage.github.io/stagecraft/ontology/TemporalRelator> ; <https://spectacular-voyage.github.io/stagecraft/ontology/subject> <https://spectacular-voyage.github.io/test-inn-ambush/target/door> ; <https://spectacular-voyage.github.io/stagecraft/ontology/predicate> <https://spectacular-voyage.github.io/stagecraft/ontology/barred> ; <https://spectacular-voyage.github.io/stagecraft/ontology/object> \"true\"^^<http://www.w3.org/2001/XMLSchema#boolean> ; <https://spectacular-voyage.github.io/stagecraft/ontology/acceptedFrom> \"2026-06-29T13:35:00Z\"^^<http://www.w3.org/2001/XMLSchema#dateTime> ; <https://spectacular-voyage.github.io/stagecraft/ontology/applicableDuring> <https://spectacular-voyage.github.io/test-inn-ambush/scene-local-time/inn-scene-plan-b> ; <https://spectacular-voyage.github.io/stagecraft/ontology/basedOnAuthorityRecord> <https://spectacular-voyage.github.io/test-inn-ambush/authority-journal/outcome-committed/plan-b-001> ; <https://spectacular-voyage.github.io/stagecraft/ontology/causedByCommittedEvent> <https://spectacular-voyage.github.io/test-inn-ambush/committed-event/plan-b-001> ; <https://spectacular-voyage.github.io/stagecraft/ontology/producedStateMutation> <https://spectacular-voyage.github.io/test-inn-ambush/state-mutation/door-barred-plan-b-001> . }",
              "expectedBoolean": true
