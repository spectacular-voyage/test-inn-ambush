          "hasAskAssertion": [
            {
              "id": "#ask-temporal-relator-min-zero-plane-typing",
              "type": "SparqlAskAssertion",
              "query": "ASK { <https://spectacular-voyage.github.io/stagecraft/shacl/TemporalRelatorShape> a <http://www.w3.org/ns/shacl#NodeShape> ; <http://www.w3.org/ns/shacl#targetClass> <https://spectacular-voyage.github.io/stagecraft/ontology/TemporalRelator> ; <http://www.w3.org/ns/shacl#property> ?acceptedFrom ; <http://www.w3.org/ns/shacl#property> ?applicableDuring . ?acceptedFrom <http://www.w3.org/ns/shacl#path> <https://spectacular-voyage.github.io/stagecraft/ontology/acceptedFrom> ; <http://www.w3.org/ns/shacl#datatype> <http://www.w3.org/2001/XMLSchema#dateTime> ; <http://www.w3.org/ns/shacl#minCount> \"0\"^^<http://www.w3.org/2001/XMLSchema#integer> ; <http://www.w3.org/ns/shacl#maxCount> \"1\"^^<http://www.w3.org/2001/XMLSchema#integer> . ?applicableDuring <http://www.w3.org/ns/shacl#path> <https://spectacular-voyage.github.io/stagecraft/ontology/applicableDuring> ; <http://www.w3.org/ns/shacl#nodeKind> <http://www.w3.org/ns/shacl#IRI> ; <http://www.w3.org/ns/shacl#class> <https://spectacular-voyage.github.io/stagecraft/ontology/TemporalAnchor> ; <http://www.w3.org/ns/shacl#minCount> \"0\"^^<http://www.w3.org/2001/XMLSchema#integer> . }",
              "expectedBoolean": true
            },
            {
              "id": "#ask-temporal-anchor-owl-time-placeholders",
              "type": "SparqlAskAssertion",
              "query": "ASK { <https://spectacular-voyage.github.io/stagecraft/shacl/TemporalAnchorShape> a <http://www.w3.org/ns/shacl#NodeShape> ; <http://www.w3.org/ns/shacl#targetClass> <https://spectacular-voyage.github.io/stagecraft/ontology/TemporalAnchor> ; <http://www.w3.org/ns/shacl#property> ?beginning ; <http://www.w3.org/ns/shacl#property> ?end . ?beginning <http://www.w3.org/ns/shacl#path> <http://www.w3.org/2006/time#hasBeginning> ; <http://www.w3.org/ns/shacl#nodeKind> <http://www.w3.org/ns/shacl#IRI> ; <http://www.w3.org/ns/shacl#class> <http://www.w3.org/2006/time#Instant> ; <http://www.w3.org/ns/shacl#minCount> \"0\"^^<http://www.w3.org/2001/XMLSchema#integer> . ?end <http://www.w3.org/ns/shacl#path> <http://www.w3.org/2006/time#hasEnd> ; <http://www.w3.org/ns/shacl#nodeKind> <http://www.w3.org/ns/shacl#IRI> ; <http://www.w3.org/ns/shacl#class> <http://www.w3.org/2006/time#Instant> ; <http://www.w3.org/ns/shacl#minCount> \"0\"^^<http://www.w3.org/2001/XMLSchema#integer> . }",
              "expectedBoolean": true
            }
          ]
        },
