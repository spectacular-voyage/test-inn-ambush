              "type": "SparqlAskAssertion",
              "query": "ASK { <https://spectacular-voyage.github.io/test-inn-ambush/relator/visibility/elara/alice-current> a <https://spectacular-voyage.github.io/stagecraft/ontology/TemporalRelator> ; <https://spectacular-voyage.github.io/stagecraft/ontology/subject> <https://spectacular-voyage.github.io/test-inn-ambush/actant/elara> ; <https://spectacular-voyage.github.io/stagecraft/ontology/predicate> <https://spectacular-voyage.github.io/stagecraft/ontology/visibleTo> ; <https://spectacular-voyage.github.io/stagecraft/ontology/object> <https://spectacular-voyage.github.io/test-inn-ambush/participant/alice> ; <https://spectacular-voyage.github.io/stagecraft/ontology/acceptedFrom> \"2026-06-29T13:35:00Z\"^^<http://www.w3.org/2001/XMLSchema#dateTime> . }",
              "expectedBoolean": true
            },
            {
              "id": "#ask-current-visible-to-relator-has-no-accepted-until",
              "type": "SparqlAskAssertion",
              "query": "ASK { <https://spectacular-voyage.github.io/test-inn-ambush/relator/visibility/elara/alice-current> <https://spectacular-voyage.github.io/stagecraft/ontology/acceptedUntil> ?until . }",
              "expectedBoolean": false
            },
            {
              "id": "#ask-superseded-visible-to-relator-closed-accepted-interval",
