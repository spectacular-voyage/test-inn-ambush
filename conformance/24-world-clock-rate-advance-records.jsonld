          "changeType": "updated",
          "compareMode": "rdfCanonical"
        }
      ],
      "hasRdfExpectation": [
        {
          "id": "#contract-shapes-rdf",
          "type": "RdfExpectation",
          "targetsFileExpectation": "#contract-shapes",
          "hasAskAssertion": [
            {
              "id": "#ask-flowing-rate-shape",
              "type": "SparqlAskAssertion",
              "query": "ASK { <https://spectacular-voyage.github.io/stagecraft/shacl/FlowingWorldTimeShape> a <http://www.w3.org/ns/shacl#NodeShape> ; <http://www.w3.org/ns/shacl#property> ?property . ?property <http://www.w3.org/ns/shacl#path> <https://spectacular-voyage.github.io/stagecraft/ontology/advancesClockEverySeconds> ; <http://www.w3.org/ns/shacl#datatype> <http://www.w3.org/2001/XMLSchema#decimal> ; <http://www.w3.org/ns/shacl#minCount> 1 ; <http://www.w3.org/ns/shacl#maxCount> 1 . <https://spectacular-voyage.github.io/stagecraft/shacl/TimeAdvancedEventShape> a <http://www.w3.org/ns/shacl#NodeShape> ; <http://www.w3.org/ns/shacl#targetClass> <https://spectacular-voyage.github.io/stagecraft/ontology/TimeAdvancedEvent> . }",
              "expectedBoolean": true
            }
          ]
        },
        {
          "id": "#world-state-rdf",
          "type": "RdfExpectation",
          "targetsFileExpectation": "#world-state",
          "hasAskAssertion": [
            {
              "id": "#ask-flowing-policy-rate-and-offset-anchor",
              "type": "SparqlAskAssertion",
              "query": "ASK { <https://spectacular-voyage.github.io/test-inn-ambush/world-time-policy/flowing-server> a <https://spectacular-voyage.github.io/stagecraft/ontology/FlowingWorldTime> ; <https://spectacular-voyage.github.io/stagecraft/ontology/advancesClockEverySeconds> \"60.0\"^^<http://www.w3.org/2001/XMLSchema#decimal> ; <https://spectacular-voyage.github.io/stagecraft/ontology/usesWorldTimeAxis> <https://spectacular-voyage.github.io/test-inn-ambush/world-time-axis/main> . <https://spectacular-voyage.github.io/test-inn-ambush/clock-anchor/world-clock/offset-960s> a <https://spectacular-voyage.github.io/stagecraft/ontology/ClockAnchor> ; <https://spectacular-voyage.github.io/stagecraft/ontology/clockOffsetSeconds> \"960.0\"^^<http://www.w3.org/2001/XMLSchema#decimal> ; <https://spectacular-voyage.github.io/stagecraft/ontology/onWorldTimeAxis> <https://spectacular-voyage.github.io/test-inn-ambush/world-time-axis/main> ; <https://spectacular-voyage.github.io/stagecraft/ontology/basedOnAuthorityRecord> <https://spectacular-voyage.github.io/test-inn-ambush/authority-journal/time-advanced/world-clock/offset-960s> . FILTER NOT EXISTS { <https://spectacular-voyage.github.io/test-inn-ambush/world-time-policy/held-elastic> <https://spectacular-voyage.github.io/stagecraft/ontology/advancesClockEverySeconds> ?heldRate . } FILTER NOT EXISTS { <https://spectacular-voyage.github.io/test-inn-ambush/clock-anchor/world-clock/offset-960s> <http://purl.org/dc/terms/created> ?anchorCreated . } }",
              "expectedBoolean": true
            }
          ]
        },
        {
          "id": "#authority-journal-rdf",
          "type": "RdfExpectation",
          "targetsFileExpectation": "#authority-journal",
          "hasAskAssertion": [
            {
              "id": "#ask-time-advanced-record-chain",
              "type": "SparqlAskAssertion",
              "query": "ASK { <https://spectacular-voyage.github.io/test-inn-ambush/authority-journal/time-advanced/world-clock/offset-960s> a <https://spectacular-voyage.github.io/stagecraft/ontology/TimeAdvanced> ; <http://purl.org/dc/terms/created> \"2026-06-29T13:37:05Z\"^^<http://www.w3.org/2001/XMLSchema#dateTime> ; <https://spectacular-voyage.github.io/stagecraft/ontology/advancesWorldTimeTo> <https://spectacular-voyage.github.io/test-inn-ambush/clock-anchor/world-clock/offset-960s> ; <https://spectacular-voyage.github.io/stagecraft/ontology/committedEvent> <https://spectacular-voyage.github.io/test-inn-ambush/committed-event/time-advanced/world-clock/offset-960s> ; <https://spectacular-voyage.github.io/stagecraft/ontology/hasCommitCertificate> <https://spectacular-voyage.github.io/test-inn-ambush/authority-journal/commit-certificate/world-clock/offset-960s> . <https://spectacular-voyage.github.io/test-inn-ambush/committed-event/time-advanced/world-clock/offset-960s> a <https://spectacular-voyage.github.io/stagecraft/ontology/TimeAdvancedEvent> ; <https://spectacular-voyage.github.io/stagecraft/ontology/advancesWorldTimeTo> <https://spectacular-voyage.github.io/test-inn-ambush/clock-anchor/world-clock/offset-960s> ; <https://spectacular-voyage.github.io/stagecraft/ontology/authorizedByAuthorityRecord> <https://spectacular-voyage.github.io/test-inn-ambush/authority-journal/time-advanced/world-clock/offset-960s> . FILTER NOT EXISTS { <https://spectacular-voyage.github.io/test-inn-ambush/committed-event/time-advanced/world-clock/offset-960s> <http://purl.org/dc/terms/created> ?eventCreated . } }",
              "expectedBoolean": true
            }
          ]
        }
      ]
