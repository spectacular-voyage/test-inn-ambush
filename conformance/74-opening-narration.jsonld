          "id": "#opening-narration-records-rdf",
          "type": "RdfExpectation",
          "targetsFileExpectation": "#world-state",
          "hasAskAssertion": [
            {
              "id": "#ask-authored-openers-cover-all-audience-selectors",
              "type": "SparqlAskAssertion",
              "query": "ASK { <https://spectacular-voyage.github.io/test-inn-ambush/opening-narration/inn-ambush/omni> a <https://spectacular-voyage.github.io/stagecraft/ontology/OpeningNarration> ; <https://spectacular-voyage.github.io/stagecraft/ontology/forActant> <https://spectacular-voyage.github.io/stagecraft/ontology/omniAudience> ; <https://spectacular-voyage.github.io/stagecraft/ontology/content> \"The prompt book opens on the Wayside Rest: every lantern, blade, and unpaid debt in view at once.\" . <https://spectacular-voyage.github.io/test-inn-ambush/opening-narration/inn-ambush/elara> a <https://spectacular-voyage.github.io/stagecraft/ontology/OpeningNarration> ; <https://spectacular-voyage.github.io/stagecraft/ontology/forActant> <https://spectacular-voyage.github.io/test-inn-ambush/actant/elara> ; <https://spectacular-voyage.github.io/stagecraft/ontology/content> \"Ashfang's worn grip warms under your palm as the common room's lantern light steadies around you.\" . <https://spectacular-voyage.github.io/test-inn-ambush/opening-narration/inn-ambush/nera> a <https://spectacular-voyage.github.io/stagecraft/ontology/OpeningNarration> ; <https://spectacular-voyage.github.io/stagecraft/ontology/forActant> <https://spectacular-voyage.github.io/test-inn-ambush/actant/nera> ; <https://spectacular-voyage.github.io/stagecraft/ontology/content> \"From the corner booth you count three exits before the foam settles on your ale.\" . <https://spectacular-voyage.github.io/test-inn-ambush/opening-narration/inn-ambush/table> a <https://spectacular-voyage.github.io/stagecraft/ontology/OpeningNarration> ; <https://spectacular-voyage.github.io/stagecraft/ontology/content> \"Evening settles over the Wayside Rest; rain taps the shutters and the fire burns low.\" . FILTER NOT EXISTS { <https://spectacular-voyage.github.io/test-inn-ambush/opening-narration/inn-ambush/table> <https://spectacular-voyage.github.io/stagecraft/ontology/forActant> ?tableAudience . } }",
              "expectedBoolean": true
            },
            {
              "id": "#ask-openers-never-carry-authored-delivery",
              "type": "SparqlAskAssertion",
              "query": "ASK { FILTER NOT EXISTS { ?opener a <https://spectacular-voyage.github.io/stagecraft/ontology/OpeningNarration> ; <https://spectacular-voyage.github.io/stagecraft/ontology/deliveredTo> ?anyone . } }",
              "expectedBoolean": true
            }
          ]
        }
      ]
    }
  ]
