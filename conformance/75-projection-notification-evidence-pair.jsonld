          "id": "#contract-shapes-rdf",
          "type": "RdfExpectation",
          "targetsFileExpectation": "#contract-shapes",
          "hasAskAssertion": [
            {
              "id": "#ask-evidence-pointers-are-paired",
              "type": "SparqlAskAssertion",
              "query": "ASK { <https://spectacular-voyage.github.io/stagecraft/shacl/ProjectionNotificationShape> <http://www.w3.org/ns/shacl#or> ?alternatives ; <http://www.w3.org/ns/shacl#property> ?authorityCardinality, ?certificateCardinality . ?authorityCardinality <http://www.w3.org/ns/shacl#path> <https://spectacular-voyage.github.io/stagecraft/ontology/authorityRecord> ; <http://www.w3.org/ns/shacl#nodeKind> <http://www.w3.org/ns/shacl#IRI> ; <http://www.w3.org/ns/shacl#maxCount> \"1\"^^<http://www.w3.org/2001/XMLSchema#integer> . ?certificateCardinality <http://www.w3.org/ns/shacl#path> <https://spectacular-voyage.github.io/stagecraft/ontology/commitCertificate> ; <http://www.w3.org/ns/shacl#nodeKind> <http://www.w3.org/ns/shacl#IRI> ; <http://www.w3.org/ns/shacl#maxCount> \"1\"^^<http://www.w3.org/2001/XMLSchema#integer> . ?alternatives <http://www.w3.org/1999/02/22-rdf-syntax-ns#first> ?presentAlternative ; <http://www.w3.org/1999/02/22-rdf-syntax-ns#rest> ?absentList . ?absentList <http://www.w3.org/1999/02/22-rdf-syntax-ns#first> ?absentAlternative ; <http://www.w3.org/1999/02/22-rdf-syntax-ns#rest> <http://www.w3.org/1999/02/22-rdf-syntax-ns#nil> . ?presentAlternative <http://www.w3.org/ns/shacl#property> ?presentAuthority, ?presentCertificate . ?presentAuthority <http://www.w3.org/ns/shacl#path> <https://spectacular-voyage.github.io/stagecraft/ontology/authorityRecord> ; <http://www.w3.org/ns/shacl#minCount> \"1\"^^<http://www.w3.org/2001/XMLSchema#integer> . ?presentCertificate <http://www.w3.org/ns/shacl#path> <https://spectacular-voyage.github.io/stagecraft/ontology/commitCertificate> ; <http://www.w3.org/ns/shacl#minCount> \"1\"^^<http://www.w3.org/2001/XMLSchema#integer> . ?absentAlternative <http://www.w3.org/ns/shacl#property> ?absentAuthority, ?absentCertificate . ?absentAuthority <http://www.w3.org/ns/shacl#path> <https://spectacular-voyage.github.io/stagecraft/ontology/authorityRecord> ; <http://www.w3.org/ns/shacl#maxCount> \"0\"^^<http://www.w3.org/2001/XMLSchema#integer> . ?absentCertificate <http://www.w3.org/ns/shacl#path> <https://spectacular-voyage.github.io/stagecraft/ontology/commitCertificate> ; <http://www.w3.org/ns/shacl#maxCount> \"0\"^^<http://www.w3.org/2001/XMLSchema#integer> . FILTER NOT EXISTS { ?authorityCardinality <http://www.w3.org/ns/shacl#minCount> ?authorityMinimum . } FILTER NOT EXISTS { ?certificateCardinality <http://www.w3.org/ns/shacl#minCount> ?certificateMinimum . } }",
              "expectedBoolean": true
            }
