  "dcterms:title": "Inn Ambush 75 projection notification evidence pair",
  "hasCase": [
    {
      "type": "TransitionCase",
      "id": "#projection-notification-evidence-pair",
      "fixtureRepo": "github.com/spectacular-voyage/test-inn-ambush",
      "operationId": "stagecraft.fixture.allowPointerlessProjectionNotification",
      "fromRef": "origin/b.22-opening-narration",
      "toRef": "origin/b.23-projection-notification-evidence-pair",
