      "hasRdfExpectation": [
        {
          "id": "#projection-shapes-rdf",
          "type": "RdfExpectation",
          "targetsFileExpectation": "#projection-shapes",
          "hasAskAssertion": [
            {
              "id": "#ask-recommendation-request-shape",
              "type": "SparqlAskAssertion",
              "query": "ASK { <https://spectacular-voyage.github.io/stagecraft/shacl/ActantIntentRecommendationRequestShape> a <http://www.w3.org/ns/shacl#NodeShape> ; <http://www.w3.org/ns/shacl#targetClass> <https://spectacular-voyage.github.io/stagecraft/ontology/ActantIntentRecommendationRequest> . }",
              "expectedBoolean": true
            },
            {
