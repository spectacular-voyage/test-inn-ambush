  "hasCase": [
    {
      "type": "TransitionCase",
      "id": "#add-plan-b-recommendation-records",
      "fixtureRepo": "github.com/spectacular-voyage/test-inn-ambush",
      "operationId": "stagecraft.fixture.addPlanBRecommendationRecords",
      "fromRef": "a.02-plan-b-woven",
      "toRef": "a.03-plan-b-recommendation-records",
