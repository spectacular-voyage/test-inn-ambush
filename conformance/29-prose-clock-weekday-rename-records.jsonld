          "hasAskAssertion": [
            {
              "id": "#ask-alphabetical-weekdays",
              "type": "SparqlAskAssertion",
              "query": "ASK { <https://spectacular-voyage.github.io/test-inn-ambush/world/calendars/inn-ambush-calendar> <https://spectacular-voyage.github.io/stagecraft/ontology/temporaenum/hasWeekday> <https://spectacular-voyage.github.io/test-inn-ambush/world/calendars/inn-ambush-calendar/weekday/ashday>, <https://spectacular-voyage.github.io/test-inn-ambush/world/calendars/inn-ambush-calendar/weekday/barrowday>, <https://spectacular-voyage.github.io/test-inn-ambush/world/calendars/inn-ambush-calendar/weekday/coinday>, <https://spectacular-voyage.github.io/test-inn-ambush/world/calendars/inn-ambush-calendar/weekday/driftday>, <https://spectacular-voyage.github.io/test-inn-ambush/world/calendars/inn-ambush-calendar/weekday/eveday> . <https://spectacular-voyage.github.io/test-inn-ambush/world/calendars/inn-ambush-calendar/weekday/ashday> <http://www.w3.org/2000/01/rdf-schema#label> \"Ashday\" ; <https://spectacular-voyage.github.io/stagecraft/ontology/temporaenum/calendarKey> \"ashday\" ; <https://spectacular-voyage.github.io/stagecraft/ontology/temporaenum/ordinal> 0 . <https://spectacular-voyage.github.io/test-inn-ambush/world/calendars/inn-ambush-calendar/weekday/barrowday> <http://www.w3.org/2000/01/rdf-schema#label> \"Barrowday\" ; <https://spectacular-voyage.github.io/stagecraft/ontology/temporaenum/calendarKey> \"barrowday\" ; <https://spectacular-voyage.github.io/stagecraft/ontology/temporaenum/ordinal> 1 . <https://spectacular-voyage.github.io/test-inn-ambush/world/calendars/inn-ambush-calendar/weekday/eveday> <http://www.w3.org/2000/01/rdf-schema#label> \"Eveday\" ; <https://spectacular-voyage.github.io/stagecraft/ontology/temporaenum/calendarKey> \"eveday\" ; <https://spectacular-voyage.github.io/stagecraft/ontology/temporaenum/ordinal> 4 . FILTER NOT EXISTS { <https://spectacular-voyage.github.io/test-inn-ambush/world/calendars/inn-ambush-calendar/weekday/toilday> ?oldToilPredicate ?oldToilObject . } FILTER NOT EXISTS { <https://spectacular-voyage.github.io/test-inn-ambush/world/calendars/inn-ambush-calendar/weekday/starday> ?oldStarPredicate ?oldStarObject . } }",
              "expectedBoolean": true
            }
