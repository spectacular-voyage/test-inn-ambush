          "targetsFileExpectation": "#world-state",
          "hasAskAssertion": [
            {
              "id": "#ask-renamed-weekday-visibility",
              "type": "SparqlAskAssertion",
              "query": "ASK { <https://spectacular-voyage.github.io/test-inn-ambush/relator/visibility/calendar/weekday-ashday/players-current> <https://spectacular-voyage.github.io/stagecraft/ontology/subject> <https://spectacular-voyage.github.io/test-inn-ambush/world/calendars/inn-ambush-calendar/weekday/ashday> ; <https://spectacular-voyage.github.io/stagecraft/ontology/object> <https://spectacular-voyage.github.io/test-inn-ambush/participant/alice>, <https://spectacular-voyage.github.io/test-inn-ambush/participant/bob> . <https://spectacular-voyage.github.io/test-inn-ambush/relator/visibility/calendar/weekday-barrowday/players-current> <https://spectacular-voyage.github.io/stagecraft/ontology/subject> <https://spectacular-voyage.github.io/test-inn-ambush/world/calendars/inn-ambush-calendar/weekday/barrowday> ; <https://spectacular-voyage.github.io/stagecraft/ontology/object> <https://spectacular-voyage.github.io/test-inn-ambush/participant/alice>, <https://spectacular-voyage.github.io/test-inn-ambush/participant/bob> . <https://spectacular-voyage.github.io/test-inn-ambush/relator/visibility/calendar/weekday-eveday/players-current> <https://spectacular-voyage.github.io/stagecraft/ontology/subject> <https://spectacular-voyage.github.io/test-inn-ambush/world/calendars/inn-ambush-calendar/weekday/eveday> ; <https://spectacular-voyage.github.io/stagecraft/ontology/object> <https://spectacular-voyage.github.io/test-inn-ambush/participant/alice>, <https://spectacular-voyage.github.io/test-inn-ambush/participant/bob> . FILTER NOT EXISTS { <https://spectacular-voyage.github.io/test-inn-ambush/relator/visibility/calendar/weekday-toilday/players-current> ?oldToilPredicate ?oldToilObject . } FILTER NOT EXISTS { <https://spectacular-voyage.github.io/test-inn-ambush/relator/visibility/calendar/weekday-starday/players-current> ?oldStarPredicate ?oldStarObject . } }",
