              "query": "ASK { <https://spectacular-voyage.github.io/test-inn-ambush/authority-journal/speech-committed/hello-barkeep-001> <https://spectacular-voyage.github.io/stagecraft/ontology/appliesConsequence> ?consequence . }",
              "expectedBoolean": false
