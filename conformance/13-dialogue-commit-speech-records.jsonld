              "id": "#ask-speech-committed-shape",
              "type": "SparqlAskAssertion",
              "query": "ASK { <https://spectacular-voyage.github.io/stagecraft/shacl/SpeechCommittedShape> a <http://www.w3.org/ns/shacl#NodeShape> ; <http://www.w3.org/ns/shacl#targetClass> <https://spectacular-voyage.github.io/stagecraft/ontology/SpeechCommitted> ; <http://www.w3.org/ns/shacl#property> ?created ; <http://www.w3.org/ns/shacl#property> ?stateMutationGuard . ?created <http://www.w3.org/ns/shacl#path> <http://purl.org/dc/terms/created> ; <http://www.w3.org/ns/shacl#datatype> <http://www.w3.org/2001/XMLSchema#dateTime> ; <http://www.w3.org/ns/shacl#minCount> \"1\"^^<http://www.w3.org/2001/XMLSchema#integer> . ?stateMutationGuard <http://www.w3.org/ns/shacl#path> <https://spectacular-voyage.github.io/stagecraft/ontology/stateMutation> ; <http://www.w3.org/ns/shacl#maxCount> \"0\"^^<http://www.w3.org/2001/XMLSchema#integer> . }",
              "expectedBoolean": true
