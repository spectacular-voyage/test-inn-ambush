          "type": "RdfExpectation",
          "targetsFileExpectation": "#authority-journal",
          "hasAskAssertion": [
            {
              "id": "#ask-speech-commit-journal-record",
              "type": "SparqlAskAssertion",
              "query": "ASK { <https://spectacular-voyage.github.io/test-inn-ambush/authority-journal/speech-committed/hello-barkeep-001> a <https://spectacular-voyage.github.io/stagecraft/ontology/SpeechCommitted> ; <http://purl.org/dc/terms/created> \"2026-06-29T13:36:00Z\"^^<http://www.w3.org/2001/XMLSchema#dateTime> ; <https://spectacular-voyage.github.io/stagecraft/ontology/committedEvent> <https://spectacular-voyage.github.io/test-inn-ambush/speech-event/hello-barkeep-001> ; <http://purl.org/dc/terms/references> <https://spectacular-voyage.github.io/test-inn-ambush/sessions/contributions/chat-contribution-hello-barkeep> . }",
              "expectedBoolean": true
