          "targetsFileExpectation": "#projection-shapes",
          "hasAskAssertion": [
            {
              "id": "#ask-committed-speech-event-shape",
              "type": "SparqlAskAssertion",
              "query": "ASK { <https://spectacular-voyage.github.io/stagecraft/shacl/CommittedSpeechEventShape> a <http://www.w3.org/ns/shacl#NodeShape> ; <http://www.w3.org/ns/shacl#targetClass> <https://spectacular-voyage.github.io/stagecraft/ontology/CommittedSpeechEvent> ; <http://www.w3.org/ns/shacl#property> ?createdGuard ; <http://www.w3.org/ns/shacl#property> ?consequenceGuard ; <http://www.w3.org/ns/shacl#property> ?delivery . ?createdGuard <http://www.w3.org/ns/shacl#path> <http://purl.org/dc/terms/created> ; <http://www.w3.org/ns/shacl#maxCount> \"0\"^^<http://www.w3.org/2001/XMLSchema#integer> . ?consequenceGuard <http://www.w3.org/ns/shacl#path> <https://spectacular-voyage.github.io/stagecraft/ontology/appliesConsequence> ; <http://www.w3.org/ns/shacl#maxCount> \"0\"^^<http://www.w3.org/2001/XMLSchema#integer> . ?delivery <http://www.w3.org/ns/shacl#path> <https://spectacular-voyage.github.io/stagecraft/ontology/deliveredTo> ; <http://www.w3.org/ns/shacl#nodeKind> <http://www.w3.org/ns/shacl#IRI> ; <http://www.w3.org/ns/shacl#minCount> \"1\"^^<http://www.w3.org/2001/XMLSchema#integer> . }",
              "expectedBoolean": true
            },
