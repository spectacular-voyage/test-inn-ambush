  "hasCase": [
    {
      "type": "TransitionCase",
      "id": "#srd-weapons-range-property-repair",
      "fixtureRepo": "github.com/spectacular-voyage/test-inn-ambush",
      "operationId": "stagecraft.fixture.repairSrdWeaponRangeProperties",
      "fromRef": "fa69dc74b18a573dca93ac119c99c0c19d2e5dd0",
