        "ref": "a.39-srd-weapons-range-property-repair"
      },
      "hasFileExpectation": [
        {
          "id": "#weapons-csv",
          "type": "FileExpectation",
          "path": "rules/dynamis/srd-5-2-1/weapons/weapons.csv",
          "changeType": "updated",
