          "changeType": "updated",
          "compareMode": "rdfCanonical"
        }
      ],
      "hasRdfExpectation": [
        {
          "id": "#weapons-rdf-expectation",
          "type": "RdfExpectation",
          "targetsFileExpectation": "#weapons-rdf",
          "hasAskAssertion": [
            {
              "id": "#ask-range-definition-and-action-distances",
              "type": "SparqlAskAssertion",
              "query": "ASK { <https://spectacular-voyage.github.io/test-inn-ambush/rules/dynamis/srd-5-2-1/weapons/property/range> a <https://spectacular-voyage.github.io/stagecraft/ontology/dynamis/WeaponPropertyDefinition> ; <https://spectacular-voyage.github.io/stagecraft/ontology/dynamis/propertyKey> \"range\" . <https://spectacular-voyage.github.io/test-inn-ambush/rules/dynamis/srd-5-2-1/weapons/item-action/handaxe-thrown> <https://spectacular-voyage.github.io/stagecraft/ontology/dynamis/normalRangeFeet> 20 ; <https://spectacular-voyage.github.io/stagecraft/ontology/dynamis/longRangeFeet> 60 . <https://spectacular-voyage.github.io/test-inn-ambush/rules/dynamis/srd-5-2-1/weapons/item-action/light-crossbow-ranged> <https://spectacular-voyage.github.io/stagecraft/ontology/dynamis/normalRangeFeet> 80 ; <https://spectacular-voyage.github.io/stagecraft/ontology/dynamis/longRangeFeet> 320 . }",
              "expectedBoolean": true
            },
            {
              "id": "#ask-no-polluted-range-property-assignments",
              "type": "SparqlAskAssertion",
              "query": "ASK { ?weapon <https://spectacular-voyage.github.io/stagecraft/ontology/dynamis/hasWeaponProperty> <https://spectacular-voyage.github.io/test-inn-ambush/rules/dynamis/srd-5-2-1/weapons/property/range> . }",
              "expectedBoolean": false
            }
          ]
        }
      ]
    }
  ]
