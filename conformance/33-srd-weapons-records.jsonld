              "query": "ASK { <https://spectacular-voyage.github.io/test-inn-ambush/rules/dynamis/srd-5-2-1/weapons/weapon/handaxe> a <https://spectacular-voyage.github.io/stagecraft/ontology/dynamis/WeaponDefinition> ; <https://spectacular-voyage.github.io/stagecraft/ontology/dynamis/damageExpression> \"1d6\" ; <https://spectacular-voyage.github.io/stagecraft/ontology/dynamis/damageType> <https://spectacular-voyage.github.io/test-inn-ambush/rules/dynamis/srd-5-2-1/weapons/damage-type/slashing> . <https://spectacular-voyage.github.io/test-inn-ambush/rules/dynamis/srd-5-2-1/weapons/item-action/handaxe-melee> <https://spectacular-voyage.github.io/stagecraft/ontology/dynamis/forItem> <https://spectacular-voyage.github.io/test-inn-ambush/rules/dynamis/srd-5-2-1/weapons/weapon/handaxe> ; <https://spectacular-voyage.github.io/stagecraft/ontology/dynamis/itemActionTestType> <https://spectacular-voyage.github.io/stagecraft/ontology/dynamis/AttackRoll> ; <https://spectacular-voyage.github.io/stagecraft/ontology/dynamis/attackMode> \"melee\" . <https://spectacular-voyage.github.io/test-inn-ambush/rules/dynamis/srd-5-2-1/weapons/item-action/handaxe-thrown> <https://spectacular-voyage.github.io/stagecraft/ontology/dynamis/forItem> <https://spectacular-voyage.github.io/test-inn-ambush/rules/dynamis/srd-5-2-1/weapons/weapon/handaxe> ; <https://spectacular-voyage.github.io/stagecraft/ontology/dynamis/itemActionTestType> <https://spectacular-voyage.github.io/stagecraft/ontology/dynamis/AttackRoll> ; <https://spectacular-voyage.github.io/stagecraft/ontology/dynamis/attackMode> \"thrown\" ; <https://spectacular-voyage.github.io/stagecraft/ontology/dynamis/normalRangeFeet> 20 ; <https://spectacular-voyage.github.io/stagecraft/ontology/dynamis/longRangeFeet> 60 . <https://spectacular-voyage.github.io/test-inn-ambush/rules/dynamis/srd-5-2-1/weapons/item-action/quarterstaff-melee-1h> <https://spectacular-voyage.github.io/stagecraft/ontology/dynamis/forItem> <https://spectacular-voyage.github.io/test-inn-ambush/rules/dynamis/srd-5-2-1/weapons/weapon/quarterstaff> ; <https://spectacular-voyage.github.io/stagecraft/ontology/dynamis/damageExpression> \"1d6\" ; <https://spectacular-voyage.github.io/stagecraft/ontology/dynamis/handsRequired> 1 . <https://spectacular-voyage.github.io/test-inn-ambush/rules/dynamis/srd-5-2-1/weapons/item-action/quarterstaff-melee-2h> <https://spectacular-voyage.github.io/stagecraft/ontology/dynamis/forItem> <https://spectacular-voyage.github.io/test-inn-ambush/rules/dynamis/srd-5-2-1/weapons/weapon/quarterstaff> ; <https://spectacular-voyage.github.io/stagecraft/ontology/dynamis/damageExpression> \"1d8\" ; <https://spectacular-voyage.github.io/stagecraft/ontology/dynamis/handsRequired> 2 . <https://spectacular-voyage.github.io/test-inn-ambush/rules/dynamis/srd-5-2-1/weapons/weapon/blowgun> <https://spectacular-voyage.github.io/stagecraft/ontology/dynamis/staticDamage> 1 ; <https://spectacular-voyage.github.io/stagecraft/ontology/dynamis/damageType> <https://spectacular-voyage.github.io/test-inn-ambush/rules/dynamis/srd-5-2-1/weapons/damage-type/piercing> . <https://spectacular-voyage.github.io/test-inn-ambush/rules/dynamis/srd-5-2-1/weapons/item-action/blowgun-ranged> <https://spectacular-voyage.github.io/stagecraft/ontology/dynamis/staticDamage> 1 ; <https://spectacular-voyage.github.io/stagecraft/ontology/dynamis/itemActionTestType> <https://spectacular-voyage.github.io/stagecraft/ontology/dynamis/AttackRoll> . FILTER NOT EXISTS { <https://spectacular-voyage.github.io/test-inn-ambush/rules/dynamis/srd-5-2-1/weapons/weapon/blowgun> <https://spectacular-voyage.github.io/stagecraft/ontology/dynamis/damageExpression> ?blowgunDice . } }",
