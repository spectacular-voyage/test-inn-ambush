@prefix dcat: <http://www.w3.org/ns/dcat#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix temp: <https://spectacular-voyage.github.io/stagecraft/ontology/temporaenum/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://spectacular-voyage.github.io/test-inn-ambush/world/calendars/inn-ambush-calendar>
  a dcat:Dataset, temp:Calendar ;
  dcterms:title "Inn Ambush custom calendar" ;
  dcterms:description "Fixture custom calendar for deriving prose world time from world-clock axis offsets. Curated CSV tables are the permanent authoring surface; this Turtle is their RDF projection for runtime reads." ;
  dcterms:created "2026-07-05"^^xsd:date ;
  temp:calendarKind "custom" ;
  temp:secondsPerDay 86400.0 ;
  temp:epochYear 1 ;
  temp:epochDayOfYear 0 ;
  temp:epochSecondOfDay 74580.0 ;
  temp:epochWeekdayOrdinal 0 ;
  temp:hasWeekday
    <https://spectacular-voyage.github.io/test-inn-ambush/world/calendars/inn-ambush-calendar/weekday/hearthday>,
    <https://spectacular-voyage.github.io/test-inn-ambush/world/calendars/inn-ambush-calendar/weekday/toilday>,
    <https://spectacular-voyage.github.io/test-inn-ambush/world/calendars/inn-ambush-calendar/weekday/marketday>,
    <https://spectacular-voyage.github.io/test-inn-ambush/world/calendars/inn-ambush-calendar/weekday/restday>,
    <https://spectacular-voyage.github.io/test-inn-ambush/world/calendars/inn-ambush-calendar/weekday/starday> ;
  temp:hasMonth
    <https://spectacular-voyage.github.io/test-inn-ambush/world/calendars/inn-ambush-calendar/month/emberwane>,
    <https://spectacular-voyage.github.io/test-inn-ambush/world/calendars/inn-ambush-calendar/month/rainmoot>,
    <https://spectacular-voyage.github.io/test-inn-ambush/world/calendars/inn-ambush-calendar/month/leafturn>,
    <https://spectacular-voyage.github.io/test-inn-ambush/world/calendars/inn-ambush-calendar/month/frostwane>,
    <https://spectacular-voyage.github.io/test-inn-ambush/world/calendars/inn-ambush-calendar/month/deepfrost>,
    <https://spectacular-voyage.github.io/test-inn-ambush/world/calendars/inn-ambush-calendar/month/thawcall>,
    <https://spectacular-voyage.github.io/test-inn-ambush/world/calendars/inn-ambush-calendar/month/seedmoot>,
    <https://spectacular-voyage.github.io/test-inn-ambush/world/calendars/inn-ambush-calendar/month/suncrest>,
    <https://spectacular-voyage.github.io/test-inn-ambush/world/calendars/inn-ambush-calendar/month/highsun>,
    <https://spectacular-voyage.github.io/test-inn-ambush/world/calendars/inn-ambush-calendar/month/harvestwane>,
    <https://spectacular-voyage.github.io/test-inn-ambush/world/calendars/inn-ambush-calendar/month/mistfall>,
    <https://spectacular-voyage.github.io/test-inn-ambush/world/calendars/inn-ambush-calendar/month/longnight> ;
  temp:hasSeason
    <https://spectacular-voyage.github.io/test-inn-ambush/world/calendars/inn-ambush-calendar/season/early-autumn>,
    <https://spectacular-voyage.github.io/test-inn-ambush/world/calendars/inn-ambush-calendar/season/deep-winter>,
    <https://spectacular-voyage.github.io/test-inn-ambush/world/calendars/inn-ambush-calendar/season/new-spring>,
    <https://spectacular-voyage.github.io/test-inn-ambush/world/calendars/inn-ambush-calendar/season/high-summer> ;
  temp:hasTimeOfDayBand
    <https://spectacular-voyage.github.io/test-inn-ambush/world/calendars/inn-ambush-calendar/band/night-before-dawn>,
    <https://spectacular-voyage.github.io/test-inn-ambush/world/calendars/inn-ambush-calendar/band/early-morning>,
    <https://spectacular-voyage.github.io/test-inn-ambush/world/calendars/inn-ambush-calendar/band/midmorning>,
    <https://spectacular-voyage.github.io/test-inn-ambush/world/calendars/inn-ambush-calendar/band/midday>,
    <https://spectacular-voyage.github.io/test-inn-ambush/world/calendars/inn-ambush-calendar/band/afternoon>,
    <https://spectacular-voyage.github.io/test-inn-ambush/world/calendars/inn-ambush-calendar/band/late-evening>,
    <https://spectacular-voyage.github.io/test-inn-ambush/world/calendars/inn-ambush-calendar/band/night-after-evening> ;
  dcat:distribution
    <https://spectacular-voyage.github.io/test-inn-ambush/world/calendars/inn-ambush-calendar/weekdays-csv>,
    <https://spectacular-voyage.github.io/test-inn-ambush/world/calendars/inn-ambush-calendar/months-csv>,
    <https://spectacular-voyage.github.io/test-inn-ambush/world/calendars/inn-ambush-calendar/seasons-csv>,
    <https://spectacular-voyage.github.io/test-inn-ambush/world/calendars/inn-ambush-calendar/bands-csv>,
    <https://spectacular-voyage.github.io/test-inn-ambush/world/calendars/inn-ambush-calendar/calendar-csvw> .

<https://spectacular-voyage.github.io/test-inn-ambush/world/calendars/inn-ambush-calendar/weekdays-csv>
